@model VolunteerBridge.ViewModels.CreateRequestViewModel
@{
    ViewBag.Title = "نشر طلب جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="w-py-xl">
    <div class="w-container">
        <div class="w-flex w-justify-center">
            <div class="w-w-full w-max-w-700">

                @* ── Breadcrumb ── *@
                <nav class="w-flex w-items-center w-gap-sm w-mb-lg w-body-sm">
                    <a asp-controller="Home" asp-action="Index" class="w-text-muted w-text-decoration-none">الرئيسية</a>
                    <span class="material-symbols-outlined w-text-faint w-icon-xs">chevron_left</span>
                    <a asp-action="MyRequests" class="w-text-muted w-text-decoration-none">طلباتي</a>
                    <span class="material-symbols-outlined w-text-faint w-icon-xs">chevron_left</span>
                    <span class="w-text-primary w-font-semibold">نشر طلب جديد</span>
                </nav>

                @* ── Form Card ── *@
                <div class="w-glass-premium w-animate-fadeInUp w-p-0 w-overflow-hidden" style="border-radius: var(--w-radius-2xl);">
                    
                    @* Card Header *@
                    <div class="w-px-xl w-py-xl" style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(167, 139, 250, 0.1)); border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                        <h1 class="w-h2 w-mb-0 w-flex w-items-center w-gap-md w-aurora-text">
                            <span class="material-symbols-outlined" style="font-size: 32px;">edit_note</span>
                            نشر طلب مساعدة جديد
                        </h1>
                    </div>

                    @* Card Body *@
                    <div class="w-p-xl">
                        <form asp-action="Create" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()

                            <div asp-validation-summary="ModelOnly" class="w-alert w-alert-error w-mb-lg"></div>

                            @* ── Title ── *@
                            <div class="w-input-group">
                                <label asp-for="Title" class="w-input-label">
                                    عنوان الطلب <span class="w-text-error">*</span>
                                </label>
                                <input asp-for="Title" class="w-input" placeholder="مثال: أحتاج مساعدة في نقل أثاث" />
                                <span asp-validation-for="Title" class="w-input-error-text"></span>
                            </div>

                            @* ── Category ── *@
                            <div class="w-input-group">
                                <label asp-for="Category" class="w-input-label">
                                    الفئة <span class="w-text-error">*</span>
                                </label>
                                <select asp-for="Category" class="w-input"
                                        asp-items="Html.GetEnumSelectList(typeof(VolunteerBridge.Models.Enums.RequestCategory))">
                                    <option value="">-- اختر الفئة --</option>
                                </select>
                                <span asp-validation-for="Category" class="w-input-error-text"></span>
                            </div>

                            @* ── Description ── *@
                            <div class="w-input-group">
                                <label asp-for="Description" class="w-input-label">
                                    وصف الطلب <span class="w-text-error">*</span>
                                </label>
                                <textarea asp-for="Description" class="w-input" rows="4" placeholder="اشرح ما تحتاجه بالتفصيل..."></textarea>
                                <span asp-validation-for="Description" class="w-input-error-text"></span>
                            </div>

                            @* ── Location ── *@
                            <div class="w-input-group">
                                <label asp-for="Location" class="w-input-label">
                                    الموقع <span class="w-text-error">*</span>
                                </label>
                                <div class="w-relative">
                                    <span class="material-symbols-outlined w-absolute w-right-0 w-top-0 w-translate-y-center w-px-md w-icon-md w-text-faint" style="pointer-events: none; top: 50%;">location_on</span>
                                    <input asp-for="Location" class="w-input" style="padding-right: 48px;" placeholder="مثال: القاهرة، المعادي" />
                                </div>
                                <span asp-validation-for="Location" class="w-input-error-text"></span>
                            </div>

                            @* ── Date + Hours Row ── *@
                            <div class="w-grid w-grid-2 w-gap-md w-mb-lg">
                                <div>
                                    <label asp-for="ScheduledDate" class="w-input-label">
                                        التاريخ المقترح <span class="w-text-error">*</span>
                                    </label>
                                    <input asp-for="ScheduledDate" type="date" class="w-input" />
                                    <span asp-validation-for="ScheduledDate" class="w-input-error-text"></span>
                                </div>
                                <div>
                                    <label asp-for="EstimatedHours" class="w-input-label">
                                        الساعات المتوقعة <span class="w-text-error">*</span>
                                    </label>
                                    <input asp-for="EstimatedHours" type="number" step="0.5" min="0.5" max="24" class="w-input" placeholder="مثال: 2" />
                                    <span asp-validation-for="EstimatedHours" class="w-input-error-text"></span>
                                    <div class="w-flex w-items-center w-gap-xs w-mt-sm w-caption w-text-muted">
                                        <span class="material-symbols-outlined w-icon-xs">info</span>
                                        النقاط = الساعات × 20 (بحد أدنى 10)
                                    </div>
                                </div>
                            </div>

                            @* ── Image Upload ── *@
                            <div class="w-input-group">
                                <label asp-for="Image" class="w-input-label">
                                    صورة توضيحية <span class="w-text-faint w-font-normal">(اختياري)</span>
                                </label>

                                <div id="uploadZone" 
                                     class="w-glass-premium w-p-2xl w-text-center w-relative w-animate-fadeIn"
                                     style="cursor: pointer; transition: all 0.3s ease; border: 2px dashed rgba(255,255,255,0.1); border-radius: var(--w-radius-xl);"
                                     onmouseenter="this.style.borderColor='var(--w-primary)'; this.style.background='rgba(99,102,241,0.05)';"
                                     onmouseleave="this.style.borderColor='rgba(255,255,255,0.1)'; this.style.background='rgba(255,255,255,0.02)';"
                                     onclick="document.getElementById('imageInput').click()">
                                    <div class="w-avatar w-avatar-lg w-mx-auto w-mb-md" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary);">
                                        <span class="material-symbols-outlined" style="font-size: 32px;">cloud_upload</span>
                                    </div>
                                    <p class="w-h3 w-mb-xs w-aurora-text">اضغط لرفع صورة</p>
                                    <p class="w-body-sm w-text-muted opacity-75">jpg, png, gif, webp (الحد الأقصى 2MB)</p>
                                </div>

                                <input asp-for="Image" type="file" class="w-hidden" id="imageInput" accept="image/*" onchange="previewImage(this)" />
                                <span asp-validation-for="Image" class="w-input-error-text"></span>

                                @* معاينة الصورة *@
                                <div id="imagePreview" class="w-mt-md w-hidden">
                                    <div class="w-relative w-flex">
                                        <img id="previewImg" src="" alt="معاينة" 
                                             class="w-h-200 w-w-auto w-rounded-md w-border" />
                                        <button type="button" onclick="removeImage()" 
                                                class="w-absolute w-top-0 w-left-0 w-m-sm w-flex w-items-center w-justify-center w-rounded-full w-bg-surface-dim w-text-white w-border-0"
                                                style="width: 28px; height: 28px; cursor: pointer; background: rgba(0,0,0,0.6);">
                                            <span class="material-symbols-outlined w-icon-xs">close</span>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            @* ── Action Buttons ── *@
                            <div class="w-flex w-justify-between w-items-center w-mt-xl w-pt-lg w-border-t">
                                <a asp-action="MyRequests" class="w-btn w-btn-ghost">
                                    إلغاء
                                </a>
                                <button type="submit" class="w-btn w-btn-primary">
                                    <span class="material-symbols-outlined w-icon-sm">send</span>
                                    نشر الطلب
                                </button>
                            </div>

                        </form>
                    </div>
                </div>

                @* ── Info Card ── *@
                <div class="w-mt-xl w-glass-premium w-p-xl w-animate-fadeInUp" style="border-radius: var(--w-radius-xl); animation-delay: 0.1s;">
                    <div class="w-flex w-gap-xl w-items-center">
                        <div class="w-avatar w-avatar-lg" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary); flex-shrink: 0;">
                            <span class="material-symbols-outlined" style="font-size: 32px;">lightbulb</span>
                        </div>
                        <div>
                            <h3 class="w-h3 w-aurora-text w-mb-xs">لماذا تطلب المساعدة عبر وصال؟</h3>
                            <p class="w-body-md w-text-muted w-leading-relaxed w-m-0">
                                من خلال منصة وصال، نهدف إلى بناء مجتمع متكافل. طلبك سيصل إلى المتطوعين الموثوقين في منطقتك، وستساهم في منحهم نقاطاً تعزز من رصيدهم التطوعي وتكرم جهودهم.
                            </p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewImage(input) {
            const preview = document.getElementById('imagePreview');
            const img = document.getElementById('previewImg');
            const uploadZone = document.getElementById('uploadZone');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    preview.style.display = 'block';
                    uploadZone.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.style.display = 'none';
                uploadZone.style.display = 'block';
            }
        }

        function removeImage() {
            const input = document.getElementById('imageInput');
            const preview = document.getElementById('imagePreview');
            const uploadZone = document.getElementById('uploadZone');
            input.value = '';
            preview.style.display = 'none';
            uploadZone.style.display = 'block';
        }
    </script>
}
