@model List<VolunteerBridge.Models.ServiceRequest>
@{
    ViewData["Title"] = "الطلبات";
    Layout = "_AdminLayout";

    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

@* ── Page Header ── *@
<div class="admin-page-header">
    <div class="admin-page-header-content">
        <div class="admin-page-icon">
            <span class="material-symbols-outlined">assignment</span>
        </div>
        <div>
            <h2 class="admin-page-title">إدارة الطلبات</h2>
            <p class="admin-page-subtitle">عرض وإدارة جميع طلبات المساعدة المقدمة في المنصة.</p>
        </div>
    </div>
    <div class="admin-page-actions">
        <a asp-action="Dashboard" class="admin-back-link">
            <span class="material-symbols-outlined">arrow_forward</span>
            العودة للوحة الإدارة
        </a>
    </div>
</div>

@* ── Requests Table ── *@
<div class="admin-table-card">
    <div class="table-responsive">
        <table class="w-table">
            <thead>
                <tr>
                    <th>مقدم الطلب</th>
                    <th>الوصف</th>
                    <th class="text-center">الفئة</th>
                    <th class="text-center">الحالة</th>
                    <th class="text-center">التاريخ</th>
                    <th class="text-left">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if(Model.Any())
                {
                    foreach (var req in Model)
                    {
                        string statusClass = req.Status switch
                        {
                            VolunteerBridge.Models.Enums.RequestStatus.Open => "w-chip-green",
                            VolunteerBridge.Models.Enums.RequestStatus.Completed => "w-chip-gray",
                            _ => "w-chip-red"
                        };
                        string statusText = req.Status switch
                        {
                            VolunteerBridge.Models.Enums.RequestStatus.Open => "مفتوح",
                            VolunteerBridge.Models.Enums.RequestStatus.Completed => "مكتمل",
                            VolunteerBridge.Models.Enums.RequestStatus.Accepted => "تم القبول",
                            VolunteerBridge.Models.Enums.RequestStatus.Cancelled => "ملغي",
                            _ => req.Status.ToString()
                        };
                        string categoryText = req.Category.ToString() switch
                        {
                            "Groceries" => "تسوق البقالة",
                            "Transportation" => "مواصلات",
                            "Cleaning" => "تنظيف",
                            "Teaching" => "تعليم",
                            "Technical" => "دعم تقني",
                            "Medical" => "طبي",
                            "Other" => "أخرى",
                            _ => req.Category.ToString()
                        };

                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="w-avatar w-avatar-sm">
                                        @(req.Requester?.FullName?.Substring(0, 1) ?? "?")
                                    </div>
                                    <div class="fw-bold" style="color: var(--w-on-surface);">
                                        @(req.Requester?.FullName ?? "غير معروف")
                                    </div>
                                </div>
                            </td>
                            <td style="max-width: 280px;">
                                <p class="text-truncate mb-0 w-body-sm" style="color: var(--w-on-surface-variant);">
                                    @req.Description
                                </p>
                            </td>
                            <td class="text-center"><span class="w-chip w-chip-blue">@categoryText</span></td>
                            <td class="text-center"><span class="w-chip @statusClass">@statusText</span></td>
                            <td class="text-center w-body-sm text-muted">@req.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-left">
                                <form asp-action="RemoveRequest" method="post" onsubmit="return confirm('هل أنت متأكد من حذف هذا الطلب؟');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@req.RequestId" />
                                    <button type="submit" class="w-btn w-btn-sm w-btn-outline-danger" style="padding: 4px 12px; font-size: 12px;">
                                        حذف
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="admin-empty-state">
                                <div class="admin-empty-state-icon">
                                    <span class="material-symbols-outlined">assignment</span>
                                </div>
                                <p class="admin-empty-state-title">لا توجد طلبات حالياً</p>
                                <p class="admin-empty-state-text">لم يتم تقديم أي طلبات مساعدة بعد.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ── Pagination ── *@
@if (totalPages > 1)
{
    <div class="admin-pagination">
        @if (currentPage > 1)
        {
            <a class="admin-pagination-btn" asp-action="Requests" asp-route-page="@(currentPage - 1)">
                <span class="material-symbols-outlined">chevron_right</span>
                السابق
            </a>
        }

        @for (int i = 1; i <= totalPages; i++)
        {
            <a class="admin-pagination-num @(i == currentPage ? "active" : "")" 
               asp-action="Requests" asp-route-page="@i">
                @i
            </a>
        }

        @if (currentPage < totalPages)
        {
            <a class="admin-pagination-btn" asp-action="Requests" asp-route-page="@(currentPage + 1)">
                التالي
                <span class="material-symbols-outlined">chevron_left</span>
            </a>
        }
    </div>
}
