@model VolunteerBridge.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "الإحصائيات";
    Layout = "_AdminLayout";

    string GetTrendClass(double g) => g >= 0 ? "admin-kpi-trend--up" : "admin-kpi-trend--down";
    string GetTrendIcon(double g) => g >= 0 ? "trending_up" : "trending_down";
    string FormatGrowth(double g) => (g > 0 ? "+" : "") + g.ToString("0.##") + "%";
}

@* ── Page Header ── *@
<div class="admin-page-header">
    <div class="admin-page-header-content">
        <div class="admin-page-icon">
            <span class="material-symbols-outlined">dashboard</span>
        </div>
        <div>
            <h2 class="admin-page-title">لوحة التحكم الإدارية</h2>
            <p class="admin-page-subtitle">نظرة عامة على أداء منصة وصال وإحصائيات المجتمع.</p>
        </div>
    </div>
    <div class="admin-page-actions">
        <a href="#" class="w-btn w-btn-outline w-btn-sm" onclick="window.print(); return false;">
            <span class="material-symbols-outlined">download</span>
            <span>تصدير التقرير</span>
        </a>
    </div>
</div>

@* ── KPI Stats Grid ── *@
<div class="admin-kpi-grid">
    @* Users *@
    <div class="admin-kpi-card">
        <div class="admin-kpi-header">
            <div>
                <div class="admin-kpi-label">إجمالي المستخدمين</div>
                <div class="admin-kpi-value">@Model.TotalUsers.ToString("N0")</div>
            </div>
            <div class="admin-kpi-icon admin-kpi-icon--primary">
                <span class="material-symbols-outlined">group</span>
            </div>
        </div>
        <div>
            <span class="admin-kpi-trend @GetTrendClass(Model.UsersGrowth)">
                <span class="material-symbols-outlined">@GetTrendIcon(Model.UsersGrowth)</span>
                @FormatGrowth(Model.UsersGrowth)
            </span>
        </div>
    </div>

    @* Active Requests *@
    <div class="admin-kpi-card">
        <div class="admin-kpi-header">
            <div>
                <div class="admin-kpi-label">الطلبات النشطة</div>
                <div class="admin-kpi-value">@Model.OpenRequests.ToString("N0")</div>
            </div>
            <div class="admin-kpi-icon admin-kpi-icon--warning">
                <span class="material-symbols-outlined">pending_actions</span>
            </div>
        </div>
        <div>
            <span class="admin-kpi-trend @GetTrendClass(Model.ActiveRequestsGrowth)">
                <span class="material-symbols-outlined">@GetTrendIcon(Model.ActiveRequestsGrowth)</span>
                @FormatGrowth(Model.ActiveRequestsGrowth)
            </span>
        </div>
    </div>

    @* Completed Tasks *@
    <div class="admin-kpi-card">
        <div class="admin-kpi-header">
            <div>
                <div class="admin-kpi-label">المهام المكتملة</div>
                <div class="admin-kpi-value">@Model.CompletedRequests.ToString("N0")</div>
            </div>
            <div class="admin-kpi-icon admin-kpi-icon--secondary">
                <span class="material-symbols-outlined">task_alt</span>
            </div>
        </div>
        <div>
            <span class="admin-kpi-trend @GetTrendClass(Model.CompletedTasksGrowth)">
                <span class="material-symbols-outlined">@GetTrendIcon(Model.CompletedTasksGrowth)</span>
                @FormatGrowth(Model.CompletedTasksGrowth)
            </span>
        </div>
    </div>

    @* Total Points *@
    <div class="admin-kpi-card">
        <div class="admin-kpi-header">
            <div>
                <div class="admin-kpi-label">إجمالي النقاط الموزعة</div>
                <div class="admin-kpi-value">@Model.TotalPointsAwarded.ToString("N0")</div>
            </div>
            <div class="admin-kpi-icon admin-kpi-icon--primary">
                <span class="material-symbols-outlined">stars</span>
            </div>
        </div>
        <div>
            <span class="admin-kpi-trend @GetTrendClass(Model.PointsGrowth)">
                <span class="material-symbols-outlined">@GetTrendIcon(Model.PointsGrowth)</span>
                @FormatGrowth(Model.PointsGrowth)
            </span>
        </div>
    </div>
</div>

@* ── Main Content: Two Columns ── *@
<div class="row g-4">
    @* Recent Activity *@
    <div class="col-lg-8">
        <div class="admin-section-card h-100">
            <div class="admin-section-header">
                <div class="admin-section-header-start">
                    <div class="admin-section-icon admin-section-icon--primary">
                        <span class="material-symbols-outlined">history</span>
                    </div>
                    <div>
                        <h5 class="admin-section-title">آخر النشاطات</h5>
                        <p class="admin-section-subtitle">أحدث الإجراءات والأحداث في المنصة.</p>
                    </div>
                </div>
            </div>
            <div class="admin-section-body">
                @if (Model.RecentActivities != null && Model.RecentActivities.Any())
                {
                    foreach (var activity in Model.RecentActivities)
                    {
                        <div class="admin-activity-item">
                            <div class="admin-activity-avatar">
                                @activity.UserInitials
                            </div>
                            <div class="admin-activity-content">
                                <div class="admin-activity-row">
                                    <span class="admin-activity-name">@activity.UserFullName</span>
                                    <span class="admin-activity-time" dir="ltr">@activity.TimeAgo</span>
                                </div>
                                <p class="admin-activity-text">@activity.ActionText <span class="text-muted">@activity.Details</span></p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="admin-empty-state">
                        <div class="admin-empty-state-icon">
                            <span class="material-symbols-outlined">history</span>
                        </div>
                        <p class="admin-empty-state-title">لا توجد نشاطات حديثة</p>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Top Volunteers *@
    <div class="col-lg-4">
        <div class="admin-section-card h-100">
            <div class="admin-section-header">
                <div class="admin-section-header-start">
                    <div class="admin-section-icon admin-section-icon--warning">
                        <span class="material-symbols-outlined">emoji_events</span>
                    </div>
                    <div>
                        <h5 class="admin-section-title">أفضل المتطوعين</h5>
                    </div>
                </div>
            </div>
            <div class="admin-section-body">
                @if (Model.TopVolunteers.Any())
                {
                    <div class="d-flex flex-column gap-2 p-3">
                        @{ var rank = 1; }
                        @foreach (var volunteer in Model.TopVolunteers.Take(5))
                        {
                            var avatarClass = rank <= 3 ? $"admin-rank-avatar--{rank}" : "admin-rank-avatar--default";
                            var itemClass = rank == 1 ? "admin-rank-item--gold" : "";

                            <div class="admin-rank-item @itemClass">
                                <div class="admin-rank-info">
                                    <div class="admin-rank-number @(rank <= 3 ? $"admin-rank-number--{rank}" : "")">@rank</div>
                                    <div class="admin-rank-avatar @avatarClass">
                                        @volunteer.FullName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="admin-rank-name">@volunteer.FullName</div>
                                        <div class="admin-rank-meta">@volunteer.Level.GetDisplayName()</div>
                                    </div>
                                </div>
                                <div class="admin-rank-score">
                                    <div class="admin-rank-score-value">@volunteer.TotalPoints</div>
                                    <div class="admin-rank-score-label">نقطة</div>
                                </div>
                            </div>
                            rank++;
                        }
                    </div>
                }
                else
                {
                    <div class="admin-empty-state">
                        <div class="admin-empty-state-icon">
                            <span class="material-symbols-outlined">emoji_events</span>
                        </div>
                        <p class="admin-empty-state-title">لا يوجد متطوعون بعد</p>
                    </div>
                }
            </div>
            <div class="admin-section-footer">
                <a asp-controller="Admin" asp-action="Users">
                    <span>إدارة جميع المستخدمين</span>
                    <span class="material-symbols-outlined" style="font-size: 16px;">arrow_back</span>
                </a>
            </div>
        </div>
    </div>
</div>
