@model VolunteerBridge.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "لوحة الإدارة";
    Layout = "_AdminLayout";
}

<div class="w-animate-fadeIn position-relative" style="padding-top: 16px; padding-bottom: 60px;">

    @* --- Background Glows --- *@
    <div class="position-absolute top-0 start-50 translate-middle-x w-100 h-100 overflow-hidden" style="z-index: -1; pointer-events: none;">
        <div class="position-absolute" style="width: 600px; height: 600px; background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%); top: -200px; left: -100px; filter: blur(80px);"></div>
        <div class="position-absolute" style="width: 500px; height: 500px; background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, transparent 70%); top: 100px; right: -150px; filter: blur(70px);"></div>
    </div>

    @* ── Header Section ── *@
    <div class="w-glass mb-5" style="border-radius: var(--w-radius-xl); border-bottom: 1px solid rgba(255,255,255,0.4);">
        <div class="p-4 p-lg-5 d-flex justify-content-between align-items-center flex-wrap gap-4">
            <div>
                <h2 class="w-h2 mb-2">لوحة التحكم الإدارية</h2>
                <p class="w-body-md text-secondary mb-0 opacity-75">نظرة عامة على أداء منصة وصال وإحصائيات المجتمع.</p>
            </div>
            <div class="d-flex gap-3">
                <a asp-action="Users" class="w-btn w-btn-outline-primary px-4">
                    <span class="material-symbols-outlined">group_manage</span>
                    <span>إدارة المستخدمين</span>
                </a>
                <a asp-action="Requests" class="w-btn w-btn-primary px-4 shadow-sm">
                    <span class="material-symbols-outlined">analytics</span>
                    <span>الطلبات</span>
                </a>
            </div>
        </div>
    </div>

    @* ── 7-Metric Stats Grid ── *@
    <div class="row g-4 mb-5 w-stagger">
        <div class="col-md-3 w-animate-fadeInUp">
            <div class="w-glass h-100 border-0 shadow-sm" style="background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.4);">
                <div class="d-flex align-items-center gap-3">
                    <div class="w-icon-container" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary); width: 56px; height: 56px; border-radius: 16px;">
                        <span class="material-symbols-outlined" style="font-size: 28px;">group</span>
                    </div>
                    <div>
                        <div class="w-body-xs text-secondary opacity-75 mb-1 fw-bold">المستخدمين</div>
                        <div class="w-h4 mb-0">@Model.TotalUsers.ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 w-animate-fadeInUp">
            <div class="w-glass h-100 border-0 shadow-sm" style="background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.4);">
                <div class="d-flex align-items-center gap-3">
                    <div class="w-icon-container" style="background: rgba(16, 185, 129, 0.1); color: var(--w-secondary); width: 56px; height: 56px; border-radius: 16px;">
                        <span class="material-symbols-outlined" style="font-size: 28px;">list_alt</span>
                    </div>
                    <div>
                        <div class="w-body-xs text-secondary opacity-75 mb-1 fw-bold">الطلبات</div>
                        <div class="w-h4 mb-0">@Model.TotalRequests.ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 w-animate-fadeInUp">
            <div class="w-glass h-100 border-0 shadow-sm" style="background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.4);">
                <div class="d-flex align-items-center gap-3">
                    <div class="w-icon-container" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9; width: 56px; height: 56px; border-radius: 16px;">
                        <span class="material-symbols-outlined" style="font-size: 28px;">task_alt</span>
                    </div>
                    <div>
                        <div class="w-body-xs text-secondary opacity-75 mb-1 fw-bold">المكتملة</div>
                        <div class="w-h4 mb-0">@Model.CompletedRequests.ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 w-animate-fadeInUp">
            <div class="w-glass h-100 border-0 shadow-sm" style="background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.4);">
                <div class="d-flex align-items-center gap-3">
                    <div class="w-icon-container" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; width: 56px; height: 56px; border-radius: 16px;">
                        <span class="material-symbols-outlined" style="font-size: 28px;">pending_actions</span>
                    </div>
                    <div>
                        <div class="w-body-xs text-secondary opacity-75 mb-1 fw-bold">المفتوحة</div>
                        <div class="w-h4 mb-0">@Model.OpenRequests.ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 w-animate-fadeInUp">
            <div class="w-glass h-100 text-white" style="background: linear-gradient(135deg, var(--w-primary) 0%, #4f46e5 100%); border: none; box-shadow: 0 10px 30px -10px rgba(99, 102, 241, 0.5);">
                <div class="d-flex align-items-center gap-3">
                    <div class="w-icon-container" style="background: rgba(255, 255, 255, 0.2); color: white; width: 56px; height: 56px; border-radius: 16px;">
                        <span class="material-symbols-outlined" style="font-size: 28px;">stars</span>
                    </div>
                    <div>
                        <div class="w-body-xs opacity-75 mb-1 fw-bold">النقاط الممنوحة</div>
                        <div class="w-h4 mb-0 text-white">@Model.TotalPointsAwarded.ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 w-animate-fadeInUp">
            <div class="w-glass h-100 border-0 shadow-sm" style="background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.4);">
                <div class="d-flex align-items-center gap-3">
                    <div class="w-icon-container" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary); width: 56px; height: 56px; border-radius: 16px;">
                        <span class="material-symbols-outlined" style="font-size: 28px;">volunteer_activism</span>
                    </div>
                    <div>
                        <div class="w-body-xs text-secondary opacity-75 mb-1 fw-bold">المتطوعون النشطون</div>
                        <div class="w-h4 mb-0">@Model.ActiveVolunteers.ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 w-animate-fadeInUp">
            <div class="w-glass h-100 border-0 shadow-sm" style="background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.4);">
                <div class="d-flex align-items-center gap-3">
                    <div class="w-icon-container" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; width: 56px; height: 56px; border-radius: 16px;">
                        <span class="material-symbols-outlined" style="font-size: 28px;">block</span>
                    </div>
                    <div>
                        <div class="w-body-xs text-secondary opacity-75 mb-1 fw-bold">المحظرون</div>
                        <div class="w-h4 mb-0 text-danger">@Model.BannedUsers.ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Top Volunteers Section ── *@
    <div class="w-glass w-p-0 w-overflow-hidden mb-5 w-animate-fadeInUp shadow-sm" style="animation-delay: 300ms; border-radius: var(--w-radius-xl); border: 1px solid rgba(255,255,255,0.4);">
        <div class="p-4 p-lg-5 d-flex justify-content-between align-items-center" style="background: rgba(255,255,255,0.4); border-bottom: 1px solid rgba(0,0,0,0.05);">
            <div class="d-flex align-items-center gap-3">
                <div class="w-icon-container bg-white shadow-sm" style="color: var(--w-secondary); border-radius: 12px;">
                    <span class="material-symbols-outlined">emoji_events</span>
                </div>
                <div>
                    <h5 class="w-h5 mb-1">لوحة الشرف</h5>
                    <p class="w-body-xs text-secondary mb-0">أكثر المتطوعين تميزاً في مجتمع وصال.</p>
                </div>
            </div>
            <a asp-controller="Leaderboard" asp-action="Index" class="w-btn w-btn-sm w-btn-outline-primary">
                <span>عرض الكل</span>
                <span class="material-symbols-outlined fs-6">arrow_back</span>
            </a>
        </div>
        <div class="table-responsive">
            <table class="w-table mb-0">
                <thead style="background: rgba(0,0,0,0.02);">
                    <tr>
                        <th class="ps-5 py-3">المتطوع</th>
                        <th class="text-center py-3">النقاط</th>
                        <th class="text-center py-3">المهام</th>
                        <th class="text-center py-3">التقييم</th>
                        <th class="text-center py-3 pe-5">المستوى</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.TopVolunteers.Any())
                    {
                        foreach (var volunteer in Model.TopVolunteers)
                        {
                            <tr style="transition: background 0.2s ease;" onmouseover="this.style.background='rgba(99,102,241,0.02)'" onmouseout="this.style.background='transparent'">
                                <td class="ps-5">
                                    <div class="d-flex align-items-center gap-3 py-1">
                                        <div class="w-avatar w-avatar-sm shadow-sm" style="background: linear-gradient(45deg, var(--w-primary) 0%, var(--w-secondary) 100%);">
                                            @volunteer.FullName.Substring(0, 1)
                                        </div>
                                        <span class="w-body-sm fw-bold">@volunteer.FullName</span>
                                    </div>
                                </td>
                                <td class="text-center"><span class="w-chip w-chip-success-light fw-bold" style="background: rgba(16,185,129,0.1);">@volunteer.TotalPoints</span></td>
                                <td class="text-center w-body-sm">@volunteer.CompletedTasksCount</td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center justify-content-center gap-1">
                                        <span class="material-symbols-outlined" style="font-size: 16px; color: #f59e0b; font-variation-settings: 'FILL' 1;">star</span>
                                        <span class="w-body-sm fw-bold">@volunteer.AverageRating.ToString("0.0")</span>
                                    </div>
                                </td>
                                <td class="text-center pe-5">
                                    <span class="w-chip w-chip-primary-light" style="background: rgba(99,102,241,0.1);">@volunteer.Level.GetDisplayName()</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-secondary opacity-50">لا يوجد متطوعون بعد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── Multi-Table Grid ── *@
    <div class="row g-4">
        @* Recent Requests *@
        <div class="col-md-6 w-animate-fadeInUp" style="animation-delay: 400ms;">
            <div class="w-card w-p-0 w-overflow-hidden h-100 border-0 shadow-sm" style="background: white;">
                <div style="padding: 20px 24px; border-bottom: 1px solid var(--w-surface-container-highest);">
                    <h6 class="w-h6 mb-0 d-flex align-items-center gap-2 w-text-primary">
                        <span class="material-symbols-outlined" style="font-size: 20px;">new_releases</span>
                        أحدث الطلبات
                    </h6>
                </div>
                <div class="table-responsive">
                    <table class="w-table" style="font-size: 13px;">
                        <thead>
                            <tr>
                                <th style="padding-right: 24px;">العنوان</th>
                                <th>بواسطة</th>
                                <th class="text-left">التاريخ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model.RecentRequests.Take(5))
                            {
                                <tr style="transition: background 0.2s ease;" onmouseover="this.style.background='rgba(99,102,241,0.01)'" onmouseout="this.style.background='transparent'">
                                    <td style="padding-right: 24px; font-weight: 500;">@req.Title</td>
                                    <td>@req.Requester?.FullName</td>
                                    <td class="text-left w-text-muted" dir="ltr">@req.CreatedAt.ToString("MMM dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* Recent Completed Tasks *@
        <div class="col-md-6 w-animate-fadeInUp" style="animation-delay: 450ms;">
            <div class="w-card w-p-0 w-overflow-hidden h-100 border-0 shadow-sm" style="background: white;">
                <div style="padding: 20px 24px; border-bottom: 1px solid var(--w-surface-container-highest);">
                    <h6 class="w-h6 mb-0 d-flex align-items-center gap-2" style="color: var(--w-secondary);">
                        <span class="material-symbols-outlined" style="font-size: 20px;">check_circle</span>
                        أحدث المهام المكتملة
                    </h6>
                </div>
                <div class="table-responsive">
                    <table class="w-table" style="font-size: 13px;">
                        <thead>
                            <tr>
                                <th style="padding-right: 24px;">المهمة</th>
                                <th>المتطوع</th>
                                <th class="text-left">التاريخ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.RecentCompletedTasks.Take(5))
                            {
                                <tr style="transition: background 0.2s ease;" onmouseover="this.style.background='rgba(16,185,129,0.01)'" onmouseout="this.style.background='transparent'">
                                    <td style="padding-right: 24px; font-weight: 500;">@task.Request?.Title</td>
                                    <td>@task.Volunteer?.FullName</td>
                                    <td class="text-left w-text-muted" dir="ltr">@task.CompletedAt?.ToString("MMM dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* Recent Ratings *@
        <div class="col-md-6 w-animate-fadeInUp" style="animation-delay: 500ms;">
            <div class="w-card w-p-0 w-overflow-hidden h-100 border-0 shadow-sm" style="background: white;">
                <div style="padding: 20px 24px; border-bottom: 1px solid var(--w-surface-container-highest);">
                    <h6 class="w-h6 mb-0 d-flex align-items-center gap-2" style="color: #f59e0b;">
                        <span class="material-symbols-outlined" style="font-size: 20px;">reviews</span>
                        أحدث التقييمات
                    </h6>
                </div>
                <div class="table-responsive">
                    <table class="w-table" style="font-size: 13px;">
                        <thead>
                            <tr>
                                <th style="padding-right: 24px;">إلى</th>
                                <th>من</th>
                                <th class="text-center">التقييم</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rating in Model.RecentRatings.Take(5))
                            {
                                <tr style="transition: background 0.2s ease;" onmouseover="this.style.background='rgba(245,158,11,0.01)'" onmouseout="this.style.background='transparent'">
                                    <td style="padding-right: 24px; font-weight: 500;">@rating.ToUser?.FullName</td>
                                    <td>@rating.FromUser?.FullName</td>
                                    <td class="text-center">
                                        <div class="d-flex align-items-center justify-content-center gap-1">
                                            <span class="material-symbols-outlined" style="font-size: 14px; color: #f59e0b; font-variation-settings: 'FILL' 1;">star</span>
                                            <span class="fw-bold">@rating.Rate</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* Recent Users *@
        <div class="col-md-6 w-animate-fadeInUp" style="animation-delay: 550ms;">
            <div class="w-card w-p-0 w-overflow-hidden h-100 border-0 shadow-sm" style="background: white;">
                <div style="padding: 20px 24px; border-bottom: 1px solid var(--w-surface-container-highest);">
                    <h6 class="w-h6 mb-0 d-flex align-items-center gap-2" style="color: var(--w-tertiary);">
                        <span class="material-symbols-outlined" style="font-size: 20px;">person_add</span>
                        أحدث المنضمين
                    </h6>
                </div>
                <div class="table-responsive">
                    <table class="w-table" style="font-size: 13px;">
                        <thead>
                            <tr>
                                <th style="padding-right: 24px;">الاسم</th>
                                <th>المدينة</th>
                                <th class="text-left">التاريخ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.RecentUsers.Take(5))
                            {
                                <tr style="transition: background 0.2s ease;" onmouseover="this.style.background='rgba(14,165,233,0.01)'" onmouseout="this.style.background='transparent'">
                                    <td style="padding-right: 24px; font-weight: 500;">@user.FullName</td>
                                    <td>@(string.IsNullOrEmpty(user.City) ? "-" : user.City)</td>
                                    <td class="text-left w-text-muted" dir="ltr">@user.CreatedAt.ToString("MMM dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>
