@model VolunteerBridge.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "لوحة الإدارة";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <h2 class="h4 mb-1">لوحة الإدارة</h2>
        <p class="text-muted mb-0">ملخص سريع عن المستخدمين والطلبات داخل المنصة.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Users" class="btn btn-outline-primary">عرض المستخدمين</a>
        <a asp-action="Requests" class="btn btn-outline-secondary">عرض الطلبات</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">إجمالي المستخدمين</div>
                <div class="fs-4 fw-bold">@Model.TotalUsers</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">إجمالي الطلبات</div>
                <div class="fs-4 fw-bold">@Model.TotalRequests</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">الطلبات المفتوحة</div>
                <div class="fs-4 fw-bold">@Model.OpenRequests</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">الطلبات المكتملة</div>
                <div class="fs-4 fw-bold">@Model.CompletedRequests</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">إجمالي النقاط الممنوحة</div>
                <div class="fs-4 fw-bold">@Model.TotalPointsAwarded</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white">
                <h3 class="h6 mb-0">أحدث المستخدمين</h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>الاسم</th>
                                <th>البريد</th>
                                <th>النقاط</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.RecentUsers)
                            {
                                <tr>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>@user.TotalPoints</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white">
                <h3 class="h6 mb-0">أحدث الطلبات</h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>العنوان</th>
                                <th>صاحب الطلب</th>
                                <th>الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.RecentRequests)
                            {
                                <tr>
                                    <td>@request.Title</td>
                                    <td>@request.Requester?.FullName</td>
                                    <td>@request.Status.GetDisplayName()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
