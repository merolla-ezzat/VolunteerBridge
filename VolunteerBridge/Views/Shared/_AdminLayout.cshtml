<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة تحكم وصال</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/wessal.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="~/VolunteerBridge.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/MainLogo.png" />
</head>
<body style="background-color: var(--w-surface);">
    <header>
        <nav class="w-navbar scrolled" style="position: sticky; border-top: 4px solid var(--w-primary);">
            <div class="w-navbar-inner">
                <a class="w-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Admin" asp-action="Dashboard">
                    <img src="~/images/MainLogo.png" alt="وصال" style="height: 32px; width: auto; vertical-align: middle;" />
                </a>
                
                @if (Context.Session.GetString("IsAdmin") == "true")
                {
                    <ul class="d-flex align-items-center gap-4 mb-0 list-unstyled p-0 m-0 flex-wrap">
                        <li>
                            <a asp-controller="Admin" asp-action="Dashboard" class="d-flex align-items-center gap-2 text-decoration-none @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "w-text-primary fw-bold" : "text-secondary")" style="font-size: 15px;">
                                <span class="material-symbols-outlined" style="font-size: 20px;">dashboard</span>
                                <span>الرئيسية</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Admin" asp-action="Users" class="d-flex align-items-center gap-2 text-decoration-none @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "w-text-primary fw-bold" : "text-secondary")" style="font-size: 15px;">
                                <span class="material-symbols-outlined" style="font-size: 20px;">group</span>
                                <span>المستخدمين</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Admin" asp-action="Requests" class="d-flex align-items-center gap-2 text-decoration-none @(ViewContext.RouteData.Values["action"]?.ToString() == "Requests" ? "w-text-primary fw-bold" : "text-secondary")" style="font-size: 15px;">
                                <span class="material-symbols-outlined" style="font-size: 20px;">list_alt</span>
                                <span>الطلبات</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Statistics" asp-action="Index" class="d-flex align-items-center gap-2 text-decoration-none @(ViewContext.RouteData.Values["controller"]?.ToString() == "Statistics" ? "w-text-primary fw-bold" : "text-secondary")" style="font-size: 15px;">
                                <span class="material-symbols-outlined" style="font-size: 20px;">bar_chart</span>
                                <span>الإحصائيات</span>
                            </a>
                        </li>
                    </ul>

                    <div class="w-nav-actions">
                        <a asp-controller="Home" asp-action="Index" class="w-btn w-btn-ghost w-btn-sm d-flex align-items-center gap-1">
                            <span class="material-symbols-outlined" style="font-size: 18px;">home</span>
                            الموقع الرئيسي
                        </a>
                        <a asp-controller="Admin" asp-action="Logout" class="w-btn w-btn-outline-danger w-btn-sm d-flex align-items-center gap-1">
                            <span class="material-symbols-outlined" style="font-size: 18px;">logout</span>
                            خروج
                        </a>
                    </div>
                }
            </div>
        </nav>
    </header>

    <div class="container" style="padding-top: 24px; padding-bottom: 40px;">
        @* ── Unified Alert System ── *@
        <div class="site-alerts">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 w-rounded-md" role="alert">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined">check_circle</span>
                        @TempData["Success"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 w-rounded-md" role="alert">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined">error</span>
                        @TempData["Error"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
                </div>
            }
        </div>

        <main role="main" class="pb-3 text-end admin-page">
            <div class="admin-bg-glows"></div>
            @RenderBody()
        </main>
    </div>

    <footer class="w-admin-footer">
        <div class="w-container">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="w-body-sm w-text-muted">&copy; 2026 - لوحة الإدارة - وصال</span>
                <span class="w-caption w-text-faint">نظام إدارة المنصة v1.0</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
