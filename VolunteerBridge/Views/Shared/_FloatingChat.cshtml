@* Views/Shared/_FloatingChat.cshtml *@
@{
    var currentUserId = Context.Session.GetInt32("UserId");
}
@if (currentUserId != null)
{
    <!-- Floating Chat Widget -->
    <div id="w-floating-chat-container" class="w-floating-chat-container">
        
        <!-- Chat Window -->
        <div id="w-chat-window" class="w-chat-window d-none">
            
            <!-- Mini Inbox View -->
            <div id="w-chat-inbox-view" class="w-chat-view active">
                <div class="w-chat-header">
                    <h5 class="w-chat-header-title">
                        <span class="material-symbols-outlined w-text-primary">chat_bubble</span>
                        المحادثات
                    </h5>
                    <div class="w-chat-header-actions">
                        <a href="/Chat/Inbox" class="w-chat-action-btn" title="فتح في صفحة كاملة" target="_self">
                            <span class="material-symbols-outlined">open_in_new</span>
                        </a>
                        <button class="w-chat-action-btn w-chat-close-btn" title="إغلاق">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                </div>
                <div id="w-chat-inbox-list" class="w-chat-inbox-list">
                    <!-- Loaded via JS -->
                    <div class="w-chat-loading-state">جاري التحميل...</div>
                </div>
            </div>

            <!-- Thread View -->
            <div id="w-chat-thread-view" class="w-chat-view slide-out-right">
                <div class="w-chat-header">
                    <div class="w-chat-header-left">
                        <button id="w-chat-back-btn" class="w-chat-action-btn w-chat-back-btn" title="رجوع">
                            <span class="material-symbols-outlined">arrow_forward</span>
                            <span id="w-chat-back-badge" class="w-chat-back-badge d-none"></span>
                        </button>
                        <div class="w-chat-thread-profile">
                            <div class="w-chat-avatar w-chat-thread-avatar" id="w-chat-thread-avatar">م</div>
                            <div class="w-chat-thread-info">
                                <div class="w-chat-header-title" id="w-chat-thread-name">مستخدم</div>
                                <div class="w-chat-header-context" id="w-chat-thread-context">متصل الآن</div>
                            </div>
                        </div>
                    </div>
                    <div class="w-chat-header-actions">
                        <a href="/Chat/Inbox" class="w-chat-action-btn" title="فتح في صفحة كاملة" target="_self">
                            <span class="material-symbols-outlined">open_in_new</span>
                        </a>
                        <button class="w-chat-action-btn w-chat-close-btn" title="إغلاق">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                </div>
                <div id="w-chat-messages" class="w-chat-messages-area">
                    <!-- Messages loaded via JS -->
                </div>
                <div class="w-chat-footer">
                    <form id="w-chat-form" class="w-chat-composer">
                        <input type="text" id="w-chat-input" class="w-chat-input" placeholder="اكتب رسالة..." autocomplete="off">
                        <button type="submit" class="w-chat-send-btn" id="w-chat-send-btn">
                            <span class="material-symbols-outlined">send</span>
                        </button>
                    </form>
                </div>
            </div>

        </div>

        <!-- Floating Launcher Button -->
        <button id="w-floating-chat-btn" class="w-floating-chat-btn">
            <span class="material-symbols-outlined" id="w-floating-chat-icon">chat</span>
            <span id="w-floating-chat-badge" class="w-floating-chat-badge d-none">0</span>
        </button>
    </div>

    <!-- Empty State Template -->
    <template id="w-chat-empty-template">
        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-center p-4">
            <div class="d-flex align-items-center justify-content-center" style="background: rgba(99, 102, 241, 0.08); color: var(--w-primary); width: 72px; height: 72px; border-radius: 50%; margin-bottom: 20px;">
                <span class="material-symbols-outlined" style="font-size: 36px;">forum</span>
            </div>
            <h6 style="font-weight: 800; color: var(--w-text-main); margin-bottom: 8px; font-size: 1.1rem;">ابدأ التواصل</h6>
            <p style="font-size: 0.95rem; color: var(--w-text-muted); margin-bottom: 24px; max-width: 240px; line-height: 1.5;">لا توجد رسائل بعد. تصفح الطلبات وتواصل مع الآخرين.</p>
            <a href="/ServiceRequests/Browse" class="w-btn w-btn-primary w-rounded-full px-4 py-2" style="font-weight: 600;">
                تصفح الطلبات
            </a>
        </div>
    </template>
}
