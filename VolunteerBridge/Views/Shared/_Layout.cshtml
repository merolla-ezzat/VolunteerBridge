<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "الرئيسية") | وصال</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/wessal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VolunteerBridge.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/MainLogo.png" />
    @RenderSection("Styles", required: false)
</head>
<body class="position-relative">
    @* --- Global Background Glows --- *@
    <div class="position-fixed top-0 start-0 w-100 h-100 overflow-hidden" style="z-index: -2; pointer-events: none;">
        <div class="position-absolute" style="width: 600px; height: 600px; background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%); top: -200px; left: -200px; filter: blur(80px); animation: aurora-pulse 15s infinite alternate;"></div>
        <div class="position-absolute" style="width: 500px; height: 500px; background: radial-gradient(circle, rgba(16, 185, 129, 0.06) 0%, transparent 70%); bottom: -100px; right: -100px; filter: blur(70px); animation: aurora-pulse 12s infinite alternate-reverse;"></div>
    </div>

    <style>
        @@keyframes aurora-pulse {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(50px, 50px) scale(1.1); }
        }
        .w-navbar {
            background: rgba(255, 255, 255, 0.6) !important;
            backdrop-filter: blur(20px) !important;
            -webkit-backdrop-filter: blur(20px) !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.3) !important;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03) !important;
        }
        .w-navbar.scrolled {
            background: rgba(255, 255, 255, 0.85) !important;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.06) !important;
        }
        .w-user-profile-btn {
            display: flex;
            align-items: center;
            padding: 0.35rem;
            background: rgba(0,0,0,0.02);
            border-radius: 50px;
            text-decoration: none;
            color: #333;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(0,0,0,0.04);
        }
        .w-user-profile-btn:hover {
            background: rgba(0,0,0,0.05);
            border-color: rgba(0,0,0,0.08);
            color: var(--w-primary);
            padding-inline-end: 1.25rem;
        }
        .w-user-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: var(--w-primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 1.15rem;
            box-shadow: 0 3px 8px rgba(99, 102, 241, 0.25);
            flex-shrink: 0;
            position: relative;
            z-index: 2;
        }
        .w-user-name-wrapper {
            max-width: 0;
            opacity: 0;
            overflow: hidden;
            white-space: nowrap;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            margin-inline-start: 0;
            transform: translateX(10px);
        }
        .w-user-profile-btn:hover .w-user-name-wrapper {
            max-width: 150px;
            opacity: 1;
            margin-inline-start: 0.85rem;
            transform: translateX(0);
        }
        .w-user-name {
            font-size: 0.95rem;
            font-weight: 600;
            letter-spacing: 0.3px;
            line-height: 1;
            margin-top: 2px;
            display: inline-block;
        }
    </style>
    @{
        var sessionUserId = Context.Session.GetInt32("UserId");
        var sessionUserName = Context.Session.GetString("UserName");
        var sessionUserEmail = Context.Session.GetString("UserEmail");
    }
    <header class="w-navbar">
        <div class="w-navbar-inner">
            <!-- Logo -->
            <a class="w-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/images/MainLogo.png" alt="وصال" style="height: 32px; width: auto; vertical-align: middle;" />
            </a>
            
            <!-- Main Nav (Desktop) -->
            @{
                var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                var action = ViewContext.RouteData.Values["action"]?.ToString();
            }
            <ul class="w-nav-links mb-0 p-0">
                <li><a class="@(controller == "Home" && action == "Index" ? "w-active" : "")" asp-controller="Home" asp-action="Index">الرئيسية</a></li>
                <li><a class="@(controller == "ServiceRequests" && action == "Browse" ? "w-active" : "")" asp-controller="ServiceRequests" asp-action="Browse">تصفح الطلبات</a></li>
                <li><a class="@(controller == "Leaderboard" ? "w-active" : "")" asp-controller="Leaderboard" asp-action="Index">لوحة الشرف</a></li>
                
                @if (Context.Session.GetInt32("UserId") != null)
                {
                    @* This link will not appear until the user navigates to a specific request *@
                    @* It is surfaced via request-specific pages (Details, MyRequests, MyTasks) *@
                }

            </ul>

            <!-- User Actions -->
            <div class="w-nav-actions">
                @if (sessionUserId != null)
                {
                    <div class="d-flex align-items-center gap-3">
                        <a asp-controller="Account" asp-action="Profile" class="w-user-profile-btn">
                            <div class="w-user-avatar">
                                @(string.IsNullOrEmpty(sessionUserName) ? "U" : sessionUserName.Substring(0, 1).ToUpper())
                            </div>
                            <div class="w-user-name-wrapper d-none d-md-block">
                                <span class="w-user-name">@sessionUserName</span>
                            </div>
                        </a>
                        <a class="w-btn w-btn-primary w-btn-sm" asp-controller="ServiceRequests" asp-action="Create">
                            <span class="material-symbols-outlined">add</span>
                            إنشاء طلب
                        </a>
                    </div>
                }
                else
                {
                    <a class="w-btn w-btn-ghost w-btn-sm d-none d-sm-inline-flex" asp-controller="Account" asp-action="Login">تسجيل الدخول</a>
                    <a class="w-btn w-btn-primary w-btn-sm" asp-controller="Account" asp-action="Register">إنشاء حساب</a>
                }
            </div>
        </div>
    </header>

    <div class="container" style="padding-top: 100px; padding-bottom: 80px;">
        @* Modified by Yousef: display shared TempData messages once in the layout for the new pages and security flows. *@
        <div class="site-alerts">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 w-rounded-md" role="alert">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined">check_circle</span>
                        @TempData["Success"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 w-rounded-md" role="alert">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined">error</span>
                        @TempData["Error"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
                </div>
            }
        </div>

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <nav class="w-bottom-nav">
        <a asp-controller="Home" asp-action="Index" class="w-bottom-nav-item @(controller == "Home" && action == "Index" ? "active" : "")">
            <span class="material-symbols-outlined">home</span>
            الرئيسية
        </a>
        <a asp-controller="ServiceRequests" asp-action="Browse" class="w-bottom-nav-item @(controller == "ServiceRequests" && action == "Browse" ? "active" : "")">
            <span class="material-symbols-outlined">search</span>
            الطلبات
        </a>
        <a asp-controller="Leaderboard" asp-action="Index" class="w-bottom-nav-item @(controller == "Leaderboard" ? "active" : "")">
            <span class="material-symbols-outlined">social_leaderboard</span>
            الشرف
        </a>
        @if (sessionUserId != null)
        {
            <a asp-controller="Account" asp-action="Profile" class="w-bottom-nav-item @(controller == "Account" && action == "Profile" ? "active" : "")">
                <span class="material-symbols-outlined">person</span>
                حسابي
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="w-bottom-nav-item @(controller == "Account" ? "active" : "")">
                <span class="material-symbols-outlined">login</span>
                دخول
            </a>
        }
    </nav>

    <footer class="w-footer w-hide-mobile">
        <div class="w-container">
            <div class="w-footer-grid">
                <div class="w-footer-brand">
                    <a class="w-footer-logo d-inline-block" asp-controller="Home" asp-action="Index">
                        <img src="~/images/MainLogo.png" alt="وصال" style="height: 78px; width: auto; vertical-align: middle;" />
                    </a>
                    <p class="w-footer-desc">
                        منصة وصال هي جسر يربط بين المتطوعين الراغبين في العطاء وبين من يحتاجون للمساعدة في مجتمعنا. نسعى لبناء مجتمع أكثر تلاحماً وتعاوناً من خلال تسهيل العمل التطوعي.
                    </p>
                </div>
                <div>
                    <h4 class="w-footer-title">روابط سريعة</h4>
                    <ul class="w-footer-links">
                        <li><a asp-controller="Home" asp-action="Index">الرئيسية</a></li>
                        <li><a asp-controller="ServiceRequests" asp-action="Browse">تصفح الطلبات</a></li>
                        <li><a asp-controller="Leaderboard" asp-action="Index">لوحة الشرف</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="w-footer-title">المساعدة</h4>
                    <ul class="w-footer-links">
                        <li><a asp-controller="Home" asp-action="Privacy">سياسة الخصوصية</a></li>
                        <li><a asp-controller="Home" asp-action="FAQ">الأسئلة الشائعة</a></li>

                    </ul>
                </div>
            </div>
            <div class="w-footer-bottom">
                <p class="mb-0">جميع الحقوق محفوظة &copy; 2026 - وصال</p>

            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
