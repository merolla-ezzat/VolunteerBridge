@{
    ViewBag.Title = "وصال - نبني جسور الخير والعطاء";
}

@section Styles {
    <style>
        .hero-section {
            min-height: 85vh;
            display: flex;
            align-items: center;
            padding: 100px 0;
            position: relative;
            overflow: hidden;
        }

        .hero-inner {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 80px;
            align-items: center;
            position: relative;
            z-index: 1;
        }

        .hero-title {
            font-family: var(--w-font-display);
            font-size: 68px;
            font-weight: 700;
            line-height: 1.1;
            color: var(--w-on-surface);
            margin-bottom: var(--w-space-xl);
        }

        .hero-title-highlight {
            position: relative;
            color: var(--w-primary);
            display: inline-block;
            white-space: nowrap;
            margin-top: 8px;
        }

        .hero-title-highlight::after {
            content: '';
            position: absolute;
            bottom: 14px;
            right: 0;
            width: 100%;
            height: 16px;
            background: var(--w-primary-container);
            z-index: -1;
            border-radius: 4px;
            opacity: 0.8;
        }

        .hero-subtitle {
            font-size: 21px;
            line-height: 1.8;
            max-width: 600px;
            color: var(--w-on-surface-variant);
            margin-bottom: var(--w-space-2xl);
            font-weight: 400;
        }

        .hero-visual {
            position: relative;
            height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .hero-card-1 {
            top: 0; right: 0;
            background: linear-gradient(135deg, var(--w-primary) 0%, #818cf8 100%);
            z-index: 3;
            box-shadow: var(--w-shadow-xl);
            transform: rotate(-4deg);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .hero-card-2 {
            top: 60px; right: 40px;
            background: var(--w-glass-bg);
            backdrop-filter: blur(20px);
            z-index: 2;
            border: 1px solid var(--w-glass-border);
            box-shadow: var(--w-shadow-lg);
            transform: rotate(2deg);
        }

        .hero-card-3 {
            top: 120px; right: 80px;
            background: var(--w-secondary-container);
            z-index: 1;
            transform: rotate(8deg);
            opacity: 0.6;
        }

        .steps-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
            margin-top: 60px;
        }

        .step-card {
            padding: 40px;
            border-radius: var(--w-radius-lg);
            transition: all var(--w-transition);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .step-card:hover {
            transform: translateY(-12px);
            background: white;
            box-shadow: var(--w-shadow-xl);
        }

        .step-number {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--w-primary-container);
            color: var(--w-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 20px;
            margin-bottom: 24px;
        }

        .step-icon-box {
            width: 80px;
            height: 80px;
            border-radius: var(--w-radius-md);
            background: var(--w-surface-dim);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            transition: all var(--w-transition);
        }

        .step-card:hover .step-icon-box {
            background: var(--w-primary-container);
            transform: scale(1.1) rotate(5deg);
        }

        .step-icon-box span {
            font-size: 36px;
            color: var(--w-primary);
        }

        @@media (max-width: 992px) {
            .hero-section { padding: 60px 0; text-align: center; }
            .hero-inner { grid-template-columns: 1fr; gap: 40px; }
            .hero-visual { display: none; }
            .hero-title { font-size: 42px; }
            .hero-subtitle { margin: 0 auto 32px; }
            .hero-actions { justify-content: center; }
            .steps-grid { grid-template-columns: 1fr; }
        }
    </style>
}

@{
    var sessionUserId = Context.Session.GetInt32("UserId");
}

<!-- ════════ HERO SECTION ════════ -->
<section class="hero-section">
    <div class="w-container">
        <div class="hero-inner">
            <div class="hero-text w-animate-fadeInUp">
                <div class="w-chip w-chip-blue w-mb-lg">
                    <span class="material-symbols-outlined w-icon-xs">volunteer_activism</span>
                    نحو مجتمع أكثر تكافلاً
                </div>

                <h1 class="hero-title">
                    وصال: نبني جسور <br>
                    <span class="hero-title-highlight">الخير والعطاء</span>
                </h1>

                <p class="hero-subtitle">
                    منصة مصرية ذكية تربط بين المتطوعين المبدعين ومن يحتاجون للمساعدة. نؤمن أن كل فعل خير، مهما كان صغيراً، يمكنه أن يغير حياة إنسان.
                </p>

                <div class="hero-actions w-flex w-gap-md w-mt-xl">
                    @if (sessionUserId == null)
                    {
                        <a asp-action="Register" asp-controller="Account" class="w-btn w-btn-primary w-btn-lg">
                            <span class="material-symbols-outlined">rocket_launch</span>
                            انضم إلينا الآن
                        </a>
                        <a asp-controller="ServiceRequests" asp-action="Browse" class="w-btn w-btn-outline w-btn-lg">
                            <span class="material-symbols-outlined">search</span>
                            تصفح الطلبات
                        </a>
                    }
                    else
                    {
                        <a asp-controller="ServiceRequests" asp-action="Browse" class="w-btn w-btn-primary w-btn-lg">
                            <span class="material-symbols-outlined">volunteer_activism</span>
                            ابدأ التطوع
                        </a>
                        <a asp-controller="ServiceRequests" asp-action="Create" class="w-btn w-btn-outline w-btn-lg">
                            <span class="material-symbols-outlined">add_circle</span>
                            اطلب مساعدة
                        </a>
                    }
                </div>
            </div>

            <div class="hero-visual w-animate-fadeIn w-delay-200">
                <div class="w-hero-card-stack">
                    <div class="w-hero-card-item hero-card-1">
                        <div class="d-flex justify-content-between align-items-start">
                            <span class="material-symbols-outlined w-icon-xl text-white" style="font-variation-settings: 'FILL' 1;">favorite</span>
                            <span class="w-chip w-chip-glass text-white">+١٢٠٠ متطوع</span>
                        </div>
                        <div>
                            <h3 class="w-h4 mb-1">أحدث تأثيراً</h3>
                            <p class="w-body-sm opacity-90">ساعد الآخرين واكتسب مهارات جديدة في رحلتك التطوعية.</p>
                        </div>
                    </div>
                    <div class="w-hero-card-item hero-card-2 p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="w-avatar w-avatar-md">أ</div>
                            <div>
                                <div class="w-label">أحمد محمد</div>
                                <div class="w-text-xs w-text-muted">قبل ١٠ دقائق</div>
                            </div>
                        </div>
                        <div class="w-body-sm">تم إنجاز طلب "توصيل دواء" بنجاح! شكرًا لكم على هذه المنصة.</div>
                    </div>
                    <div class="w-hero-card-item hero-card-3"></div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- ════════ HOW IT WORKS ════════ -->
<section class="w-py-3xl" style="background: rgba(0,0,0,0.02);">
    <div class="w-container">
        <div class="w-text-center w-mb-xl">
            <h2 class="w-h2 w-mb-md">رحلتك في وصال</h2>
            <p class="w-body-lg w-text-muted">خطوات بسيطة نحو تغيير إيجابي مستدام في المجتمع المصري.</p>
        </div>

        <div class="steps-grid">
            <div class="step-card w-glass w-animate-fadeInUp w-delay-100">
                <div class="step-number">١</div>
                <div class="step-icon-box">
                    <span class="material-symbols-outlined">person_add</span>
                </div>
                <h3 class="w-h5 w-mb-sm">انضم للمجتمع</h3>
                <p class="w-body-sm w-text-muted">أنشئ حسابك كمتطوع أو كطالب خدمة في أقل من دقيقة.</p>
            </div>

            <div class="step-card w-glass w-animate-fadeInUp w-delay-200">
                <div class="step-number">٢</div>
                <div class="step-icon-box">
                    <span class="material-symbols-outlined">explore</span>
                </div>
                <h3 class="w-h5 w-mb-sm">استكشف الفرص</h3>
                <p class="w-body-sm w-text-muted">تصفح الطلبات القريبة منك واختر ما يناسب مهاراتك ووقتك.</p>
            </div>

            <div class="step-card w-glass w-animate-fadeInUp w-delay-300">
                <div class="step-number">٣</div>
                <div class="step-icon-box" style="background: var(--w-secondary-container);">
                    <span class="material-symbols-outlined" style="color: var(--w-secondary);">celebration</span>
                </div>
                <h3 class="w-h5 w-mb-sm">اصنع الفرق</h3>
                <p class="w-body-sm w-text-muted">قدم مساعدتك، اجمع النقاط، وارتقِ في لوحة الشرف.</p>
            </div>
        </div>
    </div>
</section>

<!-- ════════ CTA SECTION ════════ -->
<section class="w-py-3xl">
    <div class="w-container">
        <div class="w-glass-premium p-5 w-text-center rounded-xl overflow-hidden position-relative">
            <h2 class="w-display w-h2 w-mb-lg">هل أنت مستعد لتكون بطلاً؟</h2>
            <p class="w-body-lg w-mb-xl w-mx-auto w-text-muted" style="max-width: 600px;">
                انضم إلى آلاف المصريين الذين يساهمون يومياً في جعل مجتمعنا مكاناً أفضل للجميع.
            </p>
            @if (sessionUserId == null)
            {
                <a asp-controller="Account" asp-action="Register" class="w-btn w-btn-primary w-btn-lg">ابدأ الآن - مجاناً</a>
            }
            else
            {
                <a asp-controller="ServiceRequests" asp-action="Browse" class="w-btn w-btn-primary w-btn-lg">تصفح أحدث الطلبات</a>
            }
        </div>
    </div>
</section>
