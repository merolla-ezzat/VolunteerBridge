@{
    ViewBag.Title = "وصال - اعمل فرق";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>وصال - اعمل فرق</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: { arabic: ["Rubik", "sans-serif"] },
                    colors: {
                        "surface-tint": "#006e2f",
                        "on-error-container": "#93000a",
                        "on-tertiary": "#ffffff",
                        "surface": "#f3fcef",
                        "surface-container-low": "#edf6ea",
                        "outline": "#6d7b6c",
                        "on-secondary-container": "#fefcff",
                        "background": "#f3fcef",
                        "on-primary": "#ffffff",
                        "secondary-container": "#316bf3",
                        "on-primary-fixed": "#002109",
                        "on-surface": "#161d16",
                        "primary-fixed-dim": "#4ae176",
                        "inverse-on-surface": "#ebf3e7",
                        "surface-dim": "#d4ddd0",
                        "surface-variant": "#dce5d9",
                        "surface-container-highest": "#dce5d9",
                        "primary-fixed": "#6bff8f",
                        "surface-container-lowest": "#ffffff",
                        "inverse-primary": "#4ae176",
                        "on-secondary-fixed": "#00174b",
                        "on-secondary": "#ffffff",
                        "error": "#ba1a1a",
                        "on-background": "#161d16",
                        "secondary-fixed": "#dbe1ff",
                        "primary-container": "#22c55e",
                        "outline-variant": "#bccbb9",
                        "secondary": "#0051d5",
                        "primary": "#006e2f",
                        "on-primary-container": "#004b1e",
                        "on-error": "#ffffff",
                        "secondary-fixed-dim": "#b4c5ff",
                        "on-surface-variant": "#3d4a3d",
                        "surface-container": "#e8f0e4",
                        "inverse-surface": "#2a322a",
                        "error-container": "#ffdad6",
                        "surface-container-high": "#e2ebde",
                        "surface-bright": "#f3fcef"
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"
                    },
                    spacing: {
                        "lg": "24px", "container-max": "1200px", "xs": "4px",
                        "md": "16px", "sm": "8px", "base": "8px", "gutter": "16px",
                        "xxl": "48px", "xl": "32px"
                    },
                    fontSize: {
                        "h2": ["32px", { "lineHeight": "1.3", "fontWeight": "700" }],
                        "body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "h1": ["40px", { "lineHeight": "1.2", "fontWeight": "700" }],
                        "h3": ["24px", { "lineHeight": "1.4", "fontWeight": "600" }],
                        "label-bold": ["14px", { "lineHeight": "1.2", "fontWeight": "600" }],
                        "caption": ["12px", { "lineHeight": "1.2", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Rubik', sans-serif;
            background-color: #f3fcef;
            color: #161d16;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col pt-20 font-arabic">

    <!-- Top Nav -->
    <nav class="bg-white/90 backdrop-blur-md text-green-600 font-arabic font-bold text-base fixed top-0 w-full border-b border-gray-100 shadow-sm z-50">
        <div class="flex flex-row-reverse justify-between items-center w-full px-6 py-4 max-w-7xl mx-auto">
            <div class="text-2xl font-black text-green-600">وصال</div>
            <div class="hidden md:flex flex-row-reverse items-center gap-6">
                <a class="text-green-600 border-b-2 border-green-600 pb-1 hover:text-green-500 transition-colors" href="#">الرئيسية</a>
                <a class="text-gray-600 hover:text-green-500 transition-colors" href="#">طلبات التطوع</a>
                <a class="text-gray-600 hover:text-green-500 transition-colors" href="#">لوحة الشرف</a>
            </div>
            <div class="flex items-center gap-4 flex-row-reverse">
                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <span class="text-label-bold text-on-surface-variant">
                        مرحباً، @Context.Session.GetString("UserName")
                    </span>
                    <a asp-action="Profile" asp-controller="Account"
                       class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
                        الملف الشخصي
                    </a>
                    <a asp-action="Logout" asp-controller="Account"
                       class="text-gray-500 hover:text-red-500 text-label-bold transition-colors">
                        خروج
                    </a>
                }
                else
                {
                    <a asp-action="Register" asp-controller="Account"
                       class="text-green-600 hover:text-green-700 font-medium transition-colors">
                        إنشاء حساب
                    </a>
                    <a asp-action="Login" asp-controller="Account"
                       class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
                        تسجيل دخول
                    </a>
                }
            </div>
        </div>
    </nav>

    <main class="flex-grow">

        <!-- Hero Section -->
        <section class="relative min-h-[819px] flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img alt="وصال"
                     class="w-full h-full object-cover opacity-20"
                     src="https://lh3.googleusercontent.com/aida-public/AB6AXuCd3AwfoKuLYZ3ZzLY7_nH1eI8Hkr5SSP-3PhCkjNgmqxcgbVOOdICApYaCDk2CsX6P48z6V1m2SGbVUgr-Ra91NMpu0SL6TTp0mNltDz459xuwoPnAoaZ74TScWrDtIMDfMJSnCemLpXYZhh5WmsHK_JMBpTnsW3F62cH2Tk5dwyVfUnvxaAXcqqRaJIVN8kRK3RI57ranPMOEczW2cZXAFRd3XBKDyYJ7hr28cjNyD4cGU4l1t_UH4fii8F26zTfhKTpIfYrCvm2M" />
                <div class="absolute inset-0 bg-gradient-to-b from-surface/80 to-surface"></div>
            </div>
            <div class="relative z-10 max-w-container-max mx-auto px-6 text-center">
                <h1 class="text-h1 font-bold text-primary-container mb-6 drop-shadow-sm">وصال — اعمل فرق</h1>
                <p class="text-h3 font-semibold text-on-surface-variant max-w-2xl mx-auto mb-10 leading-relaxed">
                    منصة تجمع بين من يحتاج المساعدة ومن يرغب بتقديمها. انضم إلى مجتمعنا وكن جزءاً من التغيير الإيجابي في مجتمعك اليوم.
                </p>
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    @if (Context.Session.GetInt32("UserId") == null)
                    {
                        <a asp-action="Register" asp-controller="Account"
                           class="bg-[#2563EB] hover:bg-blue-700 text-white px-8 py-4 rounded-xl font-semibold transition-all shadow-[0_8px_30px_rgb(37,99,235,0.2)] hover:shadow-[0_8px_30px_rgb(37,99,235,0.4)] hover:-translate-y-1 w-full sm:w-auto flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">person_add</span>
                            إنشاء حساب
                        </a>
                        <a asp-action="Login" asp-controller="Account"
                           class="bg-[#22C55E] hover:bg-green-600 text-white px-8 py-4 rounded-xl font-semibold transition-all shadow-[0_8px_30px_rgb(34,197,94,0.2)] hover:shadow-[0_8px_30px_rgb(34,197,94,0.4)] hover:-translate-y-1 w-full sm:w-auto flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">login</span>
                            تسجيل الدخول
                        </a>
                    }
                    else
                    {
                        <a asp-controller="ServiceRequests" asp-action="Create"
                           class="bg-[#2563EB] hover:bg-blue-700 text-white px-8 py-4 rounded-xl font-semibold transition-all shadow-[0_8px_30px_rgb(37,99,235,0.2)] hover:-translate-y-1 w-full sm:w-auto flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">front_hand</span>
                            اطلب مساعدة
                        </a>
                        <a asp-controller="ServiceRequests" asp-action="Browse"
                           class="bg-[#22C55E] hover:bg-green-600 text-white px-8 py-4 rounded-xl font-semibold transition-all shadow-[0_8px_30px_rgb(34,197,94,0.2)] hover:-translate-y-1 w-full sm:w-auto flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">volunteer_activism</span>
                            ساعد الآن
                        </a>
                    }
                </div>
            </div>
        </section>

        <!-- How it works -->
        <section class="py-24 bg-surface-container-low relative">
            <div class="max-w-container-max mx-auto px-6">
                <div class="text-center mb-16">
                    <h2 class="text-h2 font-bold text-primary-container mb-4">كيف تعمل منصة وصال؟</h2>
                    <p class="text-body-lg text-on-surface-variant max-w-2xl mx-auto">خطوات بسيطة تفصلك عن إحداث أثر حقيقي في مجتمعك.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
                    <div class="hidden md:block absolute top-1/2 left-0 right-0 h-0.5 bg-gradient-to-l from-primary-container/20 via-primary-container to-primary-container/20 -translate-y-1/2 z-0"></div>
                    <!-- Step 1 -->
                    <div class="relative z-10 flex flex-col items-center text-center">
                        <div class="w-20 h-20 rounded-2xl bg-white shadow-[0_8px_30px_rgb(0,0,0,0.05)] flex items-center justify-center mb-6 border border-surface-variant/50 group hover:border-primary-container transition-colors">
                            <span class="material-symbols-outlined text-4xl text-[#2563EB] group-hover:scale-110 transition-transform">post_add</span>
                        </div>
                        <h3 class="text-h3 font-semibold text-on-surface mb-3">1. إضافة الطلب</h3>
                        <p class="text-body-md text-on-surface-variant">قم بوصف المشكلة أو نوع المساعدة التي تحتاجها بوضوح وتحديد الموقع.</p>
                    </div>
                    <!-- Step 2 -->
                    <div class="relative z-10 flex flex-col items-center text-center">
                        <div class="w-20 h-20 rounded-2xl bg-white shadow-[0_8px_30px_rgb(0,0,0,0.05)] flex items-center justify-center mb-6 border border-surface-variant/50 group hover:border-primary-container transition-colors">
                            <span class="material-symbols-outlined text-4xl text-[#22C55E] group-hover:scale-110 transition-transform">connect_without_contact</span>
                        </div>
                        <h3 class="text-h3 font-semibold text-on-surface mb-3">2. التواصل والتنسيق</h3>
                        <p class="text-body-md text-on-surface-variant">يقوم المتطوعون القريبون برؤية طلبك والتواصل معك لتقديم المساعدة.</p>
                    </div>
                    <!-- Step 3 -->
                    <div class="relative z-10 flex flex-col items-center text-center">
                        <div class="w-20 h-20 rounded-2xl bg-white shadow-[0_8px_30px_rgb(0,0,0,0.05)] flex items-center justify-center mb-6 border border-surface-variant/50 group hover:border-primary-container transition-colors">
                            <span class="material-symbols-outlined text-4xl text-amber-500 group-hover:scale-110 transition-transform">task_alt</span>
                        </div>
                        <h3 class="text-h3 font-semibold text-on-surface mb-3">3. إنجاز المهمة</h3>
                        <p class="text-body-md text-on-surface-variant">يتم إنجاز المساعدة وتقييم التجربة لضمان جودة وموثوقية المنصة.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Stats -->
        <section class="py-16 bg-surface">
            <div class="max-w-container-max mx-auto px-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="glass-card rounded-2xl p-8 flex flex-col items-center justify-center text-center relative overflow-hidden">
                        <div class="absolute -right-10 -top-10 w-32 h-32 bg-primary-container/10 rounded-full blur-2xl"></div>
                        <span class="material-symbols-outlined text-5xl text-[#22C55E] mb-4">group</span>
                        <h3 class="text-h1 font-bold text-on-surface mb-2">+5,000</h3>
                        <p class="text-body-lg text-on-surface-variant">متطوع مسجل</p>
                    </div>
                    <div class="glass-card rounded-2xl p-8 flex flex-col items-center justify-center text-center relative overflow-hidden">
                        <div class="absolute -left-10 -bottom-10 w-32 h-32 bg-secondary-container/10 rounded-full blur-2xl"></div>
                        <span class="material-symbols-outlined text-5xl text-[#2563EB] mb-4">task_alt</span>
                        <h3 class="text-h1 font-bold text-on-surface mb-2">+1,200</h3>
                        <p class="text-body-lg text-on-surface-variant">طلب تم إنجازه</p>
                    </div>
                    <div class="glass-card rounded-2xl p-8 flex flex-col items-center justify-center text-center relative overflow-hidden">
                        <div class="absolute -right-10 -bottom-10 w-32 h-32 bg-primary-container/10 rounded-full blur-2xl"></div>
                        <span class="material-symbols-outlined text-5xl text-amber-500 mb-4">location_city</span>
                        <h3 class="text-h1 font-bold text-on-surface mb-2">+20</h3>
                        <p class="text-body-lg text-on-surface-variant">محافظة في أنحاء مصر </p>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <!-- Footer -->
    <footer class="bg-gray-50 text-sm font-arabic text-gray-600 w-full py-12 border-t border-gray-200 pb-24 md:pb-12">
        <div class="flex flex-col md:flex-row-reverse justify-between items-center w-full px-8 gap-6 max-w-7xl mx-auto">
            <div class="text-xl font-bold text-green-600">وصال</div>
            <div class="flex flex-row-reverse items-center gap-6">
                <a class="text-gray-500 hover:text-green-600 transition-colors" href="#">عن وصال</a>
                <a class="text-gray-500 hover:text-green-600 transition-colors" href="#">الشروط والأحكام</a>
                <a class="text-gray-500 hover:text-green-600 transition-colors" href="#">اتصل بنا</a>
            </div>
            <div>© 2026 وصال. كل الحقوق محفوظة.</div>
        </div>
    </footer>

    <!-- Bottom Nav (Mobile) -->
    <nav class="md:hidden bg-white text-[11px] font-arabic font-medium fixed bottom-0 left-0 w-full z-50 flex flex-row-reverse justify-around items-center px-4 py-3 border-t border-gray-100 shadow-[0_-4px_20px_rgba(0,0,0,0.05)] rounded-t-2xl">
        <a class="flex flex-col items-center justify-center bg-green-50 text-green-600 rounded-xl px-3 py-1" href="#">
            <span class="material-symbols-outlined mb-1" style="font-variation-settings: 'FILL' 1;">home</span>
            الرئيسية
        </a>
        <a asp-action="Login" asp-controller="Account" class="flex flex-col items-center justify-center text-gray-500 hover:bg-gray-50 px-3 py-1 rounded-xl">
            <span class="material-symbols-outlined mb-1">login</span>
            دخول
        </a>
        <a asp-action="Register" asp-controller="Account" class="flex flex-col items-center justify-center text-gray-500 hover:bg-gray-50 px-3 py-1 rounded-xl">
            <span class="material-symbols-outlined mb-1">person_add</span>
            حساب جديد
        </a>
        <a asp-action="Profile" asp-controller="Account" class="flex flex-col items-center justify-center text-gray-500 hover:bg-gray-50 px-3 py-1 rounded-xl">
            <span class="material-symbols-outlined mb-1">person</span>
            الملف
        </a>
    </nav>

</body>
</html>
