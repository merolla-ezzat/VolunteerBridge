@model VolunteerBridge.ViewModels.RegisterViewModel
@{
    ViewBag.Title = "إنشاء حساب";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>إنشاء حساب | وصال</title>
    <meta name="description" content="انضم إلى مجتمعنا وساهم في صنع التغيير عبر منصة وصال." />
    
    <link rel="stylesheet" href="~/css/wessal.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <style>
        .register-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--w-surface);
            padding: var(--w-space-md);
        }

        .register-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            max-width: 1000px;
            width: 100%;
            background: var(--w-surface-container-lowest);
            border-radius: var(--w-radius-lg);
            box-shadow: var(--w-shadow-md);
            overflow: hidden;
            /* Allow the wrapper to grow naturally based on content */
        }

        /* ── Form Side ── */
        .register-form-side {
            padding: var(--w-space-xl) var(--w-space-xl);
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow-y: auto; /* Just in case */
        }

        .register-header {
            margin-bottom: var(--w-space-xl);
        }

        .register-brand {
            font-size: 32px;
            font-weight: 700;
            color: var(--w-primary);
            text-decoration: none;
            display: inline-block;
            margin-bottom: var(--w-space-md);
        }

        .register-brand:hover { opacity: 0.9; }

        .register-title {
            font-size: 28px;
            font-weight: 600;
            color: var(--w-on-surface);
            margin-bottom: var(--w-space-sm);
        }

        .register-subtitle {
            font-size: 15px;
            color: var(--w-on-surface-variant);
            line-height: 1.5;
        }

        /* ── Input with icon ── */
        .input-with-icon {
            position: relative;
        }

        .input-with-icon .input-icon {
            position: absolute;
            top: 50%;
            right: 14px;
            transform: translateY(-50%);
            color: var(--w-outline);
            pointer-events: none;
            font-size: 20px;
        }

        .input-with-icon .w-input {
            padding-right: 46px;
        }

        /* ── Form Grid for shorter inputs ── */
        .form-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--w-space-md);
        }

        /* ── Validation ── */
        .validation-summary {
            padding: 12px 16px;
            background: var(--w-error-container);
            color: var(--w-on-error-container);
            border-radius: var(--w-radius);
            font-size: 14px;
            margin-bottom: var(--w-space-lg);
            display: none;
        }

        .validation-summary:not(:empty) {
            display: block;
        }

        .field-validation-error {
            color: var(--w-error);
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        /* ── Password Validation UI ── */
        .password-validation-container {
            margin-top: 8px;
            overflow: hidden;
            max-height: 0;
            transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s;
            opacity: 0;
        }

        .password-validation-container.active {
            max-height: 200px;
            opacity: 1;
        }

        .password-strength-meter {
            height: 4px;
            background: var(--w-surface-variant);
            border-radius: 2px;
            margin-bottom: 12px;
            overflow: hidden;
            display: flex;
        }

        .password-strength-fill {
            height: 100%;
            width: 0;
            background: var(--w-error);
            transition: width 0.3s ease, background-color 0.3s ease;
        }

        .password-checklist {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .password-checklist-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--w-on-surface-variant);
            transition: color 0.3s ease;
        }

        .password-checklist-item .material-symbols-outlined {
            font-size: 16px;
            transition: color 0.3s ease;
        }

        .password-checklist-item.valid {
            color: #10b981; /* Green */
        }
        
        .password-checklist-item.valid .material-symbols-outlined {
            color: #10b981;
        }

        /* ── Show/Hide Icon ── */
        .toggle-password {
            position: absolute;
            top: 50%;
            left: 14px;
            transform: translateY(-50%);
            color: var(--w-outline);
            cursor: pointer;
            font-size: 20px;
            user-select: none;
            transition: color 0.2s;
            z-index: 2;
        }

        .toggle-password:hover {
            color: var(--w-on-surface);
        }

        .input-with-icon .w-input.has-toggle {
            padding-left: 40px;
        }

        /* ── Visual Side ── */
        .register-visual-side {
            background: linear-gradient(135deg, var(--w-primary) 0%, #003ea8 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: var(--w-space-2xl);
            position: relative;
            overflow: hidden;
            /* Make sure it spans full height if the form gets tall */
            height: 100%;
        }

        .register-visual-side::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
            top: -50px;
            right: -80px; /* Right for RTL mirroring */
        }

        .register-visual-side::after {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            bottom: -40px;
            left: -50px;
        }

        .visual-icon {
            width: 80px;
            height: 80px;
            border-radius: var(--w-radius-md);
            background: rgba(255,255,255,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: var(--w-space-xl);
            z-index: 1;
        }

        .visual-icon .material-symbols-outlined {
            font-size: 40px;
            color: white;
            font-variation-settings: 'FILL' 1;
        }

        .visual-heading {
            font-size: 28px;
            font-weight: 600;
            color: white;
            text-align: center;
            margin-bottom: var(--w-space-md);
            line-height: 1.4;
            z-index: 1;
        }

        .visual-text {
            font-size: 15px;
            color: rgba(255,255,255,0.75);
            text-align: center;
            line-height: 1.7;
            max-width: 280px;
            z-index: 1;
        }

        /* ── Login link ── */
        .register-login-link {
            margin-top: var(--w-space-xl);
            text-align: center;
            font-size: 14px;
            color: var(--w-on-surface-variant);
        }

        .register-login-link a {
            color: var(--w-primary);
            font-weight: 600;
            text-decoration: none;
            transition: color var(--w-transition);
        }

        .register-login-link a:hover {
            color: #003ea8;
            text-decoration: underline;
        }

        /* ── Back to home ── */
        .back-home {
            position: absolute;
            top: var(--w-space-lg);
            right: var(--w-space-lg);
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 14px;
            color: var(--w-on-surface-variant);
            text-decoration: none;
            font-weight: 500;
            transition: color var(--w-transition);
            z-index: 10;
        }

        .back-home:hover { color: var(--w-primary); }
        .back-home .material-symbols-outlined { font-size: 18px; }

        @@media (max-width: 900px) {
            .register-wrapper {
                grid-template-columns: 1fr;
                max-width: 520px;
            }
            .register-visual-side { display: none; }
            .form-grid-2 { grid-template-columns: 1fr; gap: 0; }
            .register-form-side { padding: var(--w-space-xl) var(--w-space-lg); }
        }
    </style>
</head>
<body>
    <div class="register-page">
        <!-- Back to home link -->
        <a asp-controller="Home" asp-action="Index" class="back-home">
            <span class="material-symbols-outlined">arrow_forward</span>
            الرئيسية
        </a>

        <div class="register-wrapper w-animate-fadeInUp">
            <!-- ═══ Form Side ═══ -->
            <div class="register-form-side">
                <div class="register-header">
                    <a asp-controller="Home" asp-action="Index" class="register-brand">
                        <img src="~/images/MainLogo.png" alt="وصال" style="height: 38px; width: auto; object-fit: contain;" />
                    </a>
                    <h1 class="register-title">إنشاء حساب جديد</h1>
                    <p class="register-subtitle">انضم إلى مجتمعنا وساهم في صنع التغيير.</p>
                </div>

                <form asp-action="Register" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <!-- Full Name -->
                    <div class="w-input-group">
                        <label asp-for="FullName" class="w-input-label">الاسم الكامل</label>
                        <div class="input-with-icon">
                            <span class="material-symbols-outlined input-icon">person</span>
                            <input asp-for="FullName" type="text" class="w-input" placeholder="أدخل اسمك الكامل" />
                        </div>
                        <span asp-validation-for="FullName" class="field-validation-error"></span>
                    </div>

                    <!-- Email -->
                    <div class="w-input-group">
                        <label asp-for="Email" class="w-input-label">البريد الإلكتروني</label>
                        <div class="input-with-icon">
                            <span class="material-symbols-outlined input-icon">mail</span>
                            <input asp-for="Email" type="email" class="w-input" placeholder="example@domain.com" />
                        </div>
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <!-- Passwords Grid -->
                    <div class="form-grid-2">
                        <!-- Password -->
                        <div class="w-input-group" style="margin-bottom: 0;">
                            <label asp-for="Password" class="w-input-label">كلمة المرور</label>
                            <div class="input-with-icon">
                                <span class="material-symbols-outlined input-icon">lock</span>
                                <input asp-for="Password" type="password" class="w-input has-toggle" placeholder="••••••••" id="PasswordInput" />
                                <span class="material-symbols-outlined toggle-password" onclick="togglePassword('PasswordInput', this)">visibility</span>
                            </div>
                            <span asp-validation-for="Password" class="field-validation-error"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="w-input-group" style="margin-bottom: 0;">
                            <label asp-for="ConfirmPassword" class="w-input-label">تأكيد كلمة المرور</label>
                            <div class="input-with-icon">
                                <span class="material-symbols-outlined input-icon">lock_reset</span>
                                <input asp-for="ConfirmPassword" type="password" class="w-input has-toggle" placeholder="••••••••" id="ConfirmPasswordInput" />
                                <span class="material-symbols-outlined toggle-password" onclick="togglePassword('ConfirmPasswordInput', this)">visibility</span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                        </div>
                    </div>

                    <!-- Full-width Password Strength Checklist -->
                    <div class="password-validation-container" id="PasswordValidationBox" style="margin-bottom: 16px;">
                        <div class="password-strength-meter">
                            <div class="password-strength-fill" id="PasswordStrengthFill"></div>
                        </div>
                        <ul class="password-checklist">
                            <li class="password-checklist-item" id="req-length">
                                <span class="material-symbols-outlined">circle</span>
                                8 أحرف على الأقل
                            </li>
                            <li class="password-checklist-item" id="req-uppercase">
                                <span class="material-symbols-outlined">circle</span>
                                حرف كبير
                            </li>
                            <li class="password-checklist-item" id="req-number">
                                <span class="material-symbols-outlined">circle</span>
                                رقم واحد
                            </li>
                            <li class="password-checklist-item" id="req-special">
                                <span class="material-symbols-outlined">circle</span>
                                رمز خاص
                            </li>
                        </ul>
                    </div>

                    <!-- Optional Fields Grid -->
                    <div class="form-grid-2">
                        <!-- City -->
                        <div class="w-input-group">
                            <label asp-for="City" class="w-input-label">المدينة <span style="font-weight:400; color:var(--w-on-surface-variant);">(اختياري)</span></label>
                            <div class="input-with-icon">
                                <span class="material-symbols-outlined input-icon">location_city</span>
                                <select asp-for="City" class="w-input" style="appearance: none; padding-left: 40px; cursor: pointer; color: var(--w-on-surface);">
                                    <option value="" disabled selected>اختر مدينتك...</option>
                                    <option value="القاهرة">القاهرة</option>
                                    <option value="الإسكندرية">الإسكندرية</option>
                                    <option value="الجيزة">الجيزة</option>
                                    <option value="الشرقية">الشرقية</option>
                                    <option value="الدقهلية">الدقهلية</option>
                                    <option value="المنصورة">المنصورة</option>
                                    <option value="البحيرة">البحيرة</option>
                                    <option value="الغربية">الغربية</option>
                                    <option value="طنطا">طنطا</option>
                                    <option value="المنيا">المنيا</option>
                                    <option value="القليوبية">القليوبية</option>
                                    <option value="سوهاج">سوهاج</option>
                                    <option value="المنوفية">المنوفية</option>
                                    <option value="أسيوط">أسيوط</option>
                                    <option value="الفيوم">الفيوم</option>
                                    <option value="قنا">قنا</option>
                                    <option value="بني سويف">بني سويف</option>
                                    <option value="كفر الشيخ">كفر الشيخ</option>
                                    <option value="أسوان">أسوان</option>
                                    <option value="دمياط">دمياط</option>
                                    <option value="الإسماعيلية">الإسماعيلية</option>
                                    <option value="بورسعيد">بورسعيد</option>
                                    <option value="السويس">السويس</option>
                                    <option value="الأقصر">الأقصر</option>
                                </select>
                                <span class="material-symbols-outlined" style="position: absolute; top: 50%; left: 14px; transform: translateY(-50%); color: var(--w-outline); pointer-events: none; font-size: 20px;">keyboard_arrow_down</span>
                            </div>
                        </div>

                        <!-- Phone -->
                        <div class="w-input-group">
                            <label asp-for="PhoneNumber" class="w-input-label">رقم الهاتف <span style="font-weight:400; color:var(--w-on-surface-variant);">(اختياري)</span></label>
                            <div class="input-with-icon">
                                <span class="material-symbols-outlined input-icon">phone</span>
                                <input asp-for="PhoneNumber" type="tel" class="w-input" placeholder="01xxxxxxxx" dir="ltr" style="text-align:right" />
                            </div>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="w-btn w-btn-primary w-btn-lg w-btn-full" style="margin-top: var(--w-space-md);">
                        إنشاء الحساب
                        <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                    </button>
                </form>

                <div class="register-login-link">
                    لديك حساب بالفعل؟
                    <a asp-action="Login" asp-controller="Account">تسجيل الدخول</a>
                </div>
            </div>

            <!-- ═══ Visual Side ═══ -->
            <div class="register-visual-side">
                <div class="visual-icon">
                    <span class="material-symbols-outlined">group_add</span>
                </div>
                <h2 class="visual-heading">انضم إلى<br/>مجتمع العطاء</h2>
                <p class="visual-text">
                    التطوع ليس مجرد مساعدة، بل هو استثمار في بناء مجتمع أقوى وأكثر تماسكاً. ابدأ رحلتك معنا اليوم.
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePassword(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                icon.textContent = "visibility_off";
            } else {
                input.type = "password";
                icon.textContent = "visibility";
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            const passwordInput = document.getElementById("PasswordInput");
            const confirmInput = document.getElementById("ConfirmPasswordInput");
            const validationBox = document.getElementById("PasswordValidationBox");
            const strengthFill = document.getElementById("PasswordStrengthFill");
            
            const reqLength = document.getElementById("req-length");
            const reqUppercase = document.getElementById("req-uppercase");
            const reqNumber = document.getElementById("req-number");
            const reqSpecial = document.getElementById("req-special");

            let isFullyValid = false;

            function checkValidationVisibility() {
                // Delay slightly to allow activeElement to update when tabbing
                setTimeout(() => {
                    const activeEl = document.activeElement;
                    if (activeEl !== passwordInput && activeEl !== confirmInput) {
                        if (isFullyValid || passwordInput.value.length === 0) {
                            validationBox.classList.remove("active");
                        }
                    }
                }, 10);
            }

            if (!passwordInput || !confirmInput) return;

            passwordInput.addEventListener("focus", function() {
                validationBox.classList.add("active");
            });

            confirmInput.addEventListener("focus", function() {
                validationBox.classList.add("active");
            });

            passwordInput.addEventListener("blur", checkValidationVisibility);
            confirmInput.addEventListener("blur", checkValidationVisibility);

            passwordInput.addEventListener("input", function() {
                validationBox.classList.add("active");
                const val = passwordInput.value;
                let score = 0;

                // Length
                if (val.length >= 8) {
                    reqLength.classList.add("valid");
                    reqLength.querySelector("span").textContent = "check_circle";
                    score++;
                } else {
                    reqLength.classList.remove("valid");
                    reqLength.querySelector("span").textContent = "circle";
                }

                // Uppercase
                if (/[A-Z]/.test(val)) {
                    reqUppercase.classList.add("valid");
                    reqUppercase.querySelector("span").textContent = "check_circle";
                    score++;
                } else {
                    reqUppercase.classList.remove("valid");
                    reqUppercase.querySelector("span").textContent = "circle";
                }

                // Number
                if (/[0-9]/.test(val)) {
                    reqNumber.classList.add("valid");
                    reqNumber.querySelector("span").textContent = "check_circle";
                    score++;
                } else {
                    reqNumber.classList.remove("valid");
                    reqNumber.querySelector("span").textContent = "circle";
                }

                // Special (any character that is not letter or number)
                if (/[^a-zA-Z0-9]/.test(val)) {
                    reqSpecial.classList.add("valid");
                    reqSpecial.querySelector("span").textContent = "check_circle";
                    score++;
                } else {
                    reqSpecial.classList.remove("valid");
                    reqSpecial.querySelector("span").textContent = "circle";
                }

                isFullyValid = (score === 4);

                // Update Progress Bar
                strengthFill.style.width = (score * 25) + "%";
                
                if (score <= 1) {
                    strengthFill.style.backgroundColor = "var(--w-error)";
                } else if (score === 2 || score === 3) {
                    strengthFill.style.backgroundColor = "#f59e0b"; // Orange
                } else if (score === 4) {
                    strengthFill.style.backgroundColor = "#10b981"; // Green
                }
            });
        });
    </script>
</body>
</html>
