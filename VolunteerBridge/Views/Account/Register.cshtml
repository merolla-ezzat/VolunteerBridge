@model VolunteerBridge.ViewModels.RegisterViewModel
@{
    ViewBag.Title = "إنشاء حساب";
    Layout = null;
}

<!DOCTYPE html>
<html class="light" dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>وصال - إنشاء حساب</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: { arabic: ['Rubik', 'sans-serif'] },
                    colors: {
                        "surface-tint": "#006e2f",
                        "on-error-container": "#93000a",
                        "on-tertiary": "#ffffff",
                        "surface": "#f3fcef",
                        "surface-container-low": "#edf6ea",
                        "outline": "#6d7b6c",
                        "on-secondary-container": "#fefcff",
                        "background": "#f3fcef",
                        "on-primary": "#ffffff",
                        "on-surface": "#161d16",
                        "secondary-container": "#316bf3",
                        "on-primary-fixed": "#002109",
                        "surface-dim": "#d4ddd0",
                        "inverse-on-surface": "#ebf3e7",
                        "surface-variant": "#dce5d9",
                        "surface-container-highest": "#dce5d9",
                        "primary-fixed": "#6bff8f",
                        "surface-container-lowest": "#ffffff",
                        "inverse-primary": "#4ae176",
                        "on-secondary-fixed": "#00174b",
                        "on-secondary": "#ffffff",
                        "error": "#ba1a1a",
                        "on-background": "#161d16",
                        "secondary-fixed": "#dbe1ff",
                        "primary-container": "#22c55e",
                        "outline-variant": "#bccbb9",
                        "secondary": "#0051d5",
                        "primary": "#006e2f",
                        "on-primary-container": "#004b1e",
                        "on-error": "#ffffff",
                        "secondary-fixed-dim": "#b4c5ff",
                        "on-surface-variant": "#3d4a3d",
                        "surface-container": "#e8f0e4",
                        "inverse-surface": "#2a322a",
                        "error-container": "#ffdad6",
                        "surface-container-high": "#e2ebde",
                        "surface-bright": "#f3fcef"
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"
                    },
                    spacing: {
                        "lg": "24px", "container-max": "1200px", "xs": "4px",
                        "md": "16px", "sm": "8px", "base": "8px", "gutter": "16px",
                        "xxl": "48px", "xl": "32px"
                    },
                    fontSize: {
                        "h2": ["32px", { "lineHeight": "1.3", "fontWeight": "700" }],
                        "body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "h3": ["24px", { "lineHeight": "1.4", "fontWeight": "600" }],
                        "label-bold": ["14px", { "lineHeight": "1.2", "fontWeight": "600" }],
                        "caption": ["12px", { "lineHeight": "1.2", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Rubik', sans-serif;
        }
    </style>
</head>
<body class="bg-background text-on-background min-h-screen flex items-center justify-center p-md lg:p-xl font-arabic">
    <div class="w-full max-w-[1000px] bg-surface-container-lowest rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] overflow-hidden flex flex-col lg:flex-row">

        <!-- Form Section -->
        <div class="w-full lg:w-1/2 p-xl lg:p-xxl flex flex-col justify-center">
            <div class="mb-xl text-center lg:text-right">
                <a class="text-h2 font-black text-primary inline-block mb-md" href="#">وصال</a>
                <h1 class="text-h3 text-on-surface mb-sm">إنشاء حساب جديد</h1>
                <p class="text-body-md text-on-surface-variant">انضم إلى مجتمعنا وساهم في صنع التغيير.</p>
            </div>

            <form asp-action="Register" method="post" class="space-y-lg">
                @Html.AntiForgeryToken()

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="text-error text-body-sm bg-error-container p-md rounded-lg hidden [&:not(:empty)]:block"></div>

                <!-- Full Name -->
                <div class="space-y-xs">
                    <label asp-for="FullName" class="block text-label-bold text-on-surface text-right">الاسم الكامل</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 right-0 flex items-center pr-md pointer-events-none">
                            <span class="material-symbols-outlined text-outline">person</span>
                        </span>
                        <input asp-for="FullName"
                               class="block w-full pl-md pr-[48px] py-md border border-outline-variant rounded-lg bg-surface-container-lowest text-body-md text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-right"
                               placeholder="أدخل اسمك الكامل" />
                    </div>
                    <span asp-validation-for="FullName" class="text-error text-caption"></span>
                </div>

                <!-- Email -->
                <div class="space-y-xs">
                    <label asp-for="Email" class="block text-label-bold text-on-surface text-right">البريد الإلكتروني</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 right-0 flex items-center pr-md pointer-events-none">
                            <span class="material-symbols-outlined text-outline">mail</span>
                        </span>
                        <input asp-for="Email" type="email"
                               class="block w-full pl-md pr-[48px] py-md border border-outline-variant rounded-lg bg-surface-container-lowest text-body-md text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-right"
                               placeholder="example@domain.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-error text-caption"></span>
                </div>

                <!-- Password -->
                <div class="space-y-xs">
                    <label asp-for="Password" class="block text-label-bold text-on-surface text-right">كلمة المرور</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 right-0 flex items-center pr-md pointer-events-none">
                            <span class="material-symbols-outlined text-outline">lock</span>
                        </span>
                        <input asp-for="Password" type="password"
                               class="block w-full pl-md pr-[48px] py-md border border-outline-variant rounded-lg bg-surface-container-lowest text-body-md text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-right"
                               placeholder="••••••••" />
                    </div>
                    <p class="text-caption text-on-surface-variant flex items-center gap-xs mt-sm">
                        <span class="material-symbols-outlined text-[16px]">info</span>
                        يجب أن تتكون من 6 أحرف على الأقل.
                    </p>
                    <span asp-validation-for="Password" class="text-error text-caption"></span>
                </div>

                <!-- Confirm Password -->
                <div class="space-y-xs">
                    <label asp-for="ConfirmPassword" class="block text-label-bold text-on-surface text-right">تأكيد كلمة المرور</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 right-0 flex items-center pr-md pointer-events-none">
                            <span class="material-symbols-outlined text-outline">lock_reset</span>
                        </span>
                        <input asp-for="ConfirmPassword" type="password"
                               class="block w-full pl-md pr-[48px] py-md border border-outline-variant rounded-lg bg-surface-container-lowest text-body-md text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-right"
                               placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-error text-caption"></span>
                </div>

                <!-- City -->
                <div class="space-y-xs">
                    <label asp-for="City" class="block text-label-bold text-on-surface text-right">المدينة <span class="text-on-surface-variant font-normal">(اختياري)</span></label>
                    <div class="relative">
                        <span class="absolute inset-y-0 right-0 flex items-center pr-md pointer-events-none">
                            <span class="material-symbols-outlined text-outline">location_city</span>
                        </span>
                        <input asp-for="City"
                               class="block w-full pl-md pr-[48px] py-md border border-outline-variant rounded-lg bg-surface-container-lowest text-body-md text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-right"
                               placeholder="مدينتك" />
                    </div>
                </div>

                <!-- Phone -->
                <div class="space-y-xs">
                    <label asp-for="PhoneNumber" class="block text-label-bold text-on-surface text-right">رقم الهاتف <span class="text-on-surface-variant font-normal">(اختياري)</span></label>
                    <div class="relative">
                        <span class="absolute inset-y-0 right-0 flex items-center pr-md pointer-events-none">
                            <span class="material-symbols-outlined text-outline">phone</span>
                        </span>
                        <input asp-for="PhoneNumber"
                               class="block w-full pl-md pr-[48px] py-md border border-outline-variant rounded-lg bg-surface-container-lowest text-body-md text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-right"
                               placeholder="05xxxxxxxx" />
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit"
                        class="w-full bg-primary-container text-on-primary py-md px-lg rounded-lg text-label-bold hover:bg-primary transition-colors focus:ring-2 focus:ring-offset-2 focus:ring-primary-container outline-none flex items-center justify-center gap-sm">
                    إنشاء حساب
                    <span class="material-symbols-outlined">arrow_back</span>
                </button>
            </form>

            <div class="mt-lg text-center">
                <p class="text-body-sm text-on-surface-variant">
                    لديك حساب بالفعل؟
                    <a asp-action="Login" class="text-primary hover:text-surface-tint font-bold transition-colors">تسجيل الدخول</a>
                </p>
            </div>
        </div>

        <div class="hidden lg:block lg:w-1/2 relative bg-surface-container">
            <img alt="Community volunteer image"
                 class="absolute inset-0 w-full h-full object-cover rounded-l-xl"
                 src="/images/Register.jpg" />  
            <div class="absolute inset-0 bg-primary/20 mix-blend-multiply rounded-l-xl"></div>
        </div>

    </div>

    @section Scripts {
        @await Html.PartialAsync("_ValidationScriptsPartial")
    }
</body>
</html>
