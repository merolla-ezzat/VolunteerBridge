@model VolunteerBridge.ViewModels.LoginViewModel
@{
    ViewBag.Title = "تسجيل الدخول";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>وصال - تسجيل الدخول</title>
    <meta name="description" content="سجّل دخولك إلى منصة وصال للتطوع والمساهمة في مجتمعك." />
    <link rel="stylesheet" href="~/css/wessal.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        .login-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--w-surface);
            padding: var(--w-space-md);
        }

        .login-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            max-width: 960px;
            width: 100%;
            background: var(--w-surface-container-lowest);
            border-radius: var(--w-radius-lg);
            box-shadow: var(--w-shadow-md);
            overflow: hidden;
            min-height: 560px;
        }

        /* ── Form Side ── */
        .login-form-side {
            padding: var(--w-space-2xl) var(--w-space-xl);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-header {
            margin-bottom: var(--w-space-xl);
        }

        .login-brand {
            font-size: 32px;
            font-weight: 700;
            color: var(--w-primary);
            text-decoration: none;
            display: inline-block;
            margin-bottom: var(--w-space-lg);
        }

        .login-brand:hover { opacity: 0.9; }

        .login-title {
            font-size: 28px;
            font-weight: 600;
            color: var(--w-on-surface);
            margin-bottom: var(--w-space-sm);
        }

        .login-subtitle {
            font-size: 15px;
            color: var(--w-on-surface-variant);
            line-height: 1.5;
        }

        /* ── Input with icon ── */
        .input-with-icon {
            position: relative;
        }

        .input-with-icon .input-icon {
            position: absolute;
            top: 50%;
            right: 14px;
            transform: translateY(-50%);
            color: var(--w-outline);
            pointer-events: none;
            font-size: 20px;
        }

        .input-with-icon .w-input {
            padding-right: 46px;
        }

        /* ── Validation ── */
        .validation-summary {
            padding: 12px 16px;
            background: var(--w-error-container);
            color: var(--w-on-error-container);
            border-radius: var(--w-radius);
            font-size: 14px;
            margin-bottom: var(--w-space-lg);
            display: none;
        }

        .validation-summary:not(:empty) {
            display: block;
        }

        .field-validation-error {
            color: var(--w-error);
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        /* ── Visual Side ── */
        .login-visual-side {
            background: linear-gradient(135deg, var(--w-primary) 0%, #003ea8 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: var(--w-space-2xl);
            position: relative;
            overflow: hidden;
        }

        .login-visual-side::before {
            content: '';
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
            top: -40px;
            left: -60px;
        }

        .login-visual-side::after {
            content: '';
            position: absolute;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            bottom: -30px;
            right: -40px;
        }

        .visual-icon {
            width: 80px;
            height: 80px;
            border-radius: var(--w-radius-md);
            background: rgba(255,255,255,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: var(--w-space-xl);
        }

        .visual-icon .material-symbols-outlined {
            font-size: 40px;
            color: white;
            font-variation-settings: 'FILL' 1;
        }

        .visual-heading {
            font-size: 28px;
            font-weight: 600;
            color: white;
            text-align: center;
            margin-bottom: var(--w-space-md);
            line-height: 1.4;
        }

        .visual-text {
            font-size: 15px;
            color: rgba(255,255,255,0.75);
            text-align: center;
            line-height: 1.7;
            max-width: 280px;
        }

        /* ── Register link ── */
        .login-register-link {
            margin-top: var(--w-space-xl);
            text-align: center;
            font-size: 14px;
            color: var(--w-on-surface-variant);
        }

        .login-register-link a {
            color: var(--w-primary);
            font-weight: 600;
            text-decoration: none;
            transition: color var(--w-transition);
        }

        .login-register-link a:hover {
            color: #003ea8;
            text-decoration: underline;
        }

        /* ── Back to home ── */
        .back-home {
            position: absolute;
            top: var(--w-space-lg);
            right: var(--w-space-lg);
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 14px;
            color: var(--w-on-surface-variant);
            text-decoration: none;
            font-weight: 500;
            transition: color var(--w-transition);
            z-index: 10;
        }

        .back-home:hover { color: var(--w-primary); }
        .back-home .material-symbols-outlined { font-size: 18px; }

        @@media (max-width: 768px) {
            .login-wrapper {
                grid-template-columns: 1fr;
                max-width: 480px;
            }
            .login-visual-side { display: none; }
            .login-form-side { padding: var(--w-space-xl) var(--w-space-lg); }
        }
    </style>
</head>
<body>
    <div class="login-page">
        <!-- Back to home link -->
        <a asp-controller="Home" asp-action="Index" class="back-home">
            <span class="material-symbols-outlined">arrow_forward</span>
            الرئيسية
        </a>

        <div class="login-wrapper w-animate-fadeInUp">
            <!-- ═══ Form Side ═══ -->
            <div class="login-form-side">
                <div class="login-header">
                    <a asp-controller="Home" asp-action="Index" class="login-brand">
                        <img src="~/images/MainLogo.png" alt="وصال" style="height: 38px; width: auto; object-fit: contain;" />
                    </a>
                    <h1 class="login-title">مرحباً بعودتك</h1>
                    <p class="login-subtitle">سجّل دخولك للمتابعة والمساهمة في مجتمعك.</p>
                </div>

                <form asp-action="Login" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <!-- Email -->
                    <div class="w-input-group">
                        <label asp-for="Email" class="w-input-label">البريد الإلكتروني</label>
                        <div class="input-with-icon">
                            <span class="material-symbols-outlined input-icon">mail</span>
                            <input asp-for="Email" type="email" class="w-input" placeholder="example@domain.com" />
                        </div>
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <!-- Password -->
                    <div class="w-input-group">
                        <label asp-for="Password" class="w-input-label">كلمة المرور</label>
                        <div class="input-with-icon">
                            <span class="material-symbols-outlined input-icon">lock</span>
                            <input asp-for="Password" type="password" class="w-input" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="w-btn w-btn-primary w-btn-lg w-btn-full" style="margin-top: var(--w-space-sm);">
                        تسجيل الدخول
                        <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                    </button>
                </form>

                <div class="login-register-link">
                    ليس لديك حساب؟
                    <a asp-action="Register" asp-controller="Account">إنشاء حساب جديد</a>
                </div>
            </div>

            <!-- ═══ Visual Side ═══ -->
            <div class="login-visual-side">
                <div class="visual-icon">
                    <span class="material-symbols-outlined">handshake</span>
                </div>
                <h2 class="visual-heading">ساهم في<br/>بناء مجتمعك</h2>
                <p class="visual-text">
                    من خلال وصال، يمكنك تقديم المساعدة لمن يحتاجها أو طلب الدعم من متطوعين في منطقتك.
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
