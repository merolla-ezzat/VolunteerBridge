@model VolunteerBridge.Models.User
@{
    ViewData["Title"] = "الملف الشخصي";
    var userId = Context.Session.GetInt32("UserId");
}

<div dir="rtl" lang="ar" class="w-container pt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Profile Hero Section -->
            <div class="w-glass-premium p-0 overflow-hidden mb-4 w-animate-fadeInUp">
                <div class="p-5 text-center position-relative" style="height: 180px; background: radial-gradient(circle at 20% 30%, rgba(99, 102, 241, 0.4), transparent 50%), radial-gradient(circle at 80% 70%, rgba(16, 185, 129, 0.3), transparent 50%), var(--w-primary); background-blend-mode: overlay;">
                    <div class="position-absolute start-50 translate-middle-x" style="bottom: -55px;">
                        <div class="bg-white p-1 rounded-circle shadow-lg" style="background: rgba(255, 255, 255, 0.2) !important; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3);">
                            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                            {
                                <img src="@Model.ProfilePictureUrl" alt="@Model.FullName" class="rounded-circle" style="width: 110px; height: 110px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="w-bg-surface-container rounded-circle d-flex align-items-center justify-content-center overflow-hidden" style="width: 110px; height: 110px; background: var(--w-surface-container-highest);">
                                    <span class="material-symbols-outlined w-text-primary" style="font-size: 80px; font-variation-settings: 'FILL' 1;">account_circle</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="pt-5 pb-5 text-center mt-4">
                    <h1 class="w-h2 mb-1 w-aurora-text">@Model.FullName</h1>
                    <div class="d-flex justify-content-center align-items-center gap-3 mt-3 w-text-muted">
                        @if (!string.IsNullOrEmpty(Model.City))
                        {
                            <span class="d-flex align-items-center gap-1">
                                <span class="material-symbols-outlined" style="font-size: 18px;">location_on</span>
                                @Model.City
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="row g-4 mb-4 w-animate-fadeInUp w-delay-100">
                <!-- Points Card -->
                <div class="col-md-3 col-6">
                    <div class="w-glass-premium text-center h-100 p-4">
                        <div class="w-icon-container w-mx-auto w-mb-md" style="background: rgba(16, 185, 129, 0.1); color: #10b981; box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);">
                            <span class="material-symbols-outlined w-icon-lg" style="font-variation-settings: 'FILL' 1;">stars</span>
                        </div>
                        <h3 class="w-caption w-text-muted mb-1">النقاط</h3>
                        <p class="w-h3 mb-0 w-aurora-text">@Model.TotalPoints</p>
                    </div>
                </div>

                <!-- Completed Tasks -->
                <div class="col-md-3 col-6">
                    <div class="w-glass-premium text-center h-100 p-4">
                        <div class="w-icon-container w-mx-auto w-mb-md" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary); box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);">
                            <span class="material-symbols-outlined w-icon-lg" style="font-variation-settings: 'FILL' 1;">task_alt</span>
                        </div>
                        <h3 class="w-caption w-text-muted mb-1">المهام المكتملة</h3>
                        <p class="w-h3 mb-0 text-primary">@Model.CompletedTasksCount</p>
                    </div>
                </div>

                <!-- Rating -->
                <div class="col-md-3 col-6">
                    <div class="w-glass-premium text-center h-100 p-4">
                        <div class="w-icon-container w-mx-auto w-mb-md" style="background: rgba(251, 191, 36, 0.1); color: #fbbf24; box-shadow: 0 0 20px rgba(251, 191, 36, 0.2);">
                            <span class="material-symbols-outlined w-icon-lg" style="font-variation-settings: 'FILL' 1;">grade</span>
                        </div>
                        <h3 class="w-caption w-text-muted mb-1">التقييم</h3>
                        @if (Model.AverageRating > 0)
                        {
                            <p class="w-h3 mb-0 text-warning" style="text-shadow: 0 2px 10px rgba(251,191,36,0.2);">@Model.AverageRating.ToString("0.0")</p>
                        }
                        else
                        {
                            <p class="w-body-sm mb-0 py-2 w-text-muted">جديد</p>
                        }
                    </div>
                </div>

                <!-- Level -->
                <div class="col-md-3 col-6">
                    <div class="w-glass-premium text-center h-100 p-4 d-flex flex-column align-items-center justify-content-center">
                        <div class="w-icon-container w-mx-auto w-mb-md" style="background: rgba(168, 85, 247, 0.1); color: #a855f7; box-shadow: 0 0 20px rgba(168, 85, 247, 0.2);">
                            <span class="material-symbols-outlined w-icon-lg" style="font-variation-settings: 'FILL' 1;">military_tech</span>
                        </div>
                        <h3 class="w-caption w-text-muted mb-2">المستوى</h3>
                        <div class="mt-auto">
                            @switch (Model.Level)
                            {
                                case UserLevel.Newcomer:
                                    <span class="w-chip badge-newcomer px-3">مبتدئ الخير</span>
                                    break;
                                case UserLevel.Helper:
                                    <span class="w-chip badge-helper px-3">صانع الفرق</span>
                                    break;
                                case UserLevel.Trusted:
                                    <span class="w-chip badge-trusted px-3">موثوق العطاء</span>
                                    break;
                                case UserLevel.Champion:
                                    <span class="w-chip badge-champion px-3">بطل المجتمع</span>
                                    break;
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Details Sections -->
            <div class="row g-4 w-animate-fadeInUp w-delay-200">
                <!-- Bio -->
                <div class="col-12">
                    <div class="w-glass-premium p-4">
                        <h3 class="w-h5 mb-3 fw-bold d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined" style="color:var(--w-primary); font-variation-settings:'FILL' 1;">person_pin</span>
                            نبذة شخصية
                        </h3>
                        @if (!string.IsNullOrEmpty(Model.Bio))
                        {
                            <p class="w-body-md w-text-muted mb-0" style="line-height:1.8;">@Model.Bio</p>
                        }
                        else
                        {
                            <p class="w-body-md mb-0 text-muted fst-italic">لم يقم هذا المتطوع بإضافة نبذة شخصية حتى الآن.</p>
                        }
                    </div>
                </div>

                <!-- Skills -->
                <div class="col-md-6">
                    <div class="w-glass-premium p-4 h-100">
                        <h3 class="w-h5 mb-3 fw-bold d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined" style="color:var(--w-primary); font-variation-settings:'FILL' 1;">psychology</span>
                            المهارات
                        </h3>
                        @if (!string.IsNullOrEmpty(Model.Skills))
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var skill in Model.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="w-chip" style="background: rgba(99,102,241,0.1); color: var(--w-primary); font-size:13px; padding: 6px 14px; border-radius: 20px;">
                                        @skill.Trim()
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="w-body-md mb-0 text-muted fst-italic">لم تُضف مهارات بعد.</p>
                        }
                    </div>
                </div>

                <!-- Experience -->
                <div class="col-md-6">
                    <div class="w-glass-premium p-4 h-100">
                        <h3 class="w-h5 mb-3 fw-bold d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined" style="color:var(--w-primary); font-variation-settings:'FILL' 1;">workspace_premium</span>
                            الخبرات
                        </h3>
                        @if (!string.IsNullOrEmpty(Model.Experience))
                        {
                            <p class="w-body-md w-text-muted mb-0" style="line-height:1.8;">@Model.Experience</p>
                        }
                        else
                        {
                            <p class="w-body-md mb-0 text-muted fst-italic">لم تُضف خبرات بعد.</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-center gap-3 mt-5 mb-4 flex-wrap">
                @if (userId != null && userId != Model.UserId)
                {
                    <button type="button" onclick="window.WessalChat && window.WessalChat.openThread(@Model.UserId, '@Html.Raw(Model.FullName)', '', '', '@Model.ProfilePictureUrl')" 
                            class="w-btn w-btn-primary px-5 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined">forum</span>
                        مراسلة المتطوع
                    </button>
                }
                <a asp-action="Browse" asp-controller="ServiceRequests" class="w-btn w-btn-outline px-5 d-flex align-items-center gap-2">
                    العودة لمتصفح الطلبات
                </a>
            </div>

        </div>
    </div>
</div>