@{
    ViewBag.Title = "تحقق من بريدك";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;700&display=swap" rel="stylesheet" />
    <style>
        body {
            font-family: 'Rubik', sans-serif;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-[#f3fcef]">
    <div class="bg-white rounded-xl shadow p-12 text-center max-w-md">
        <div class="text-2xl font-bold text-[#006e2f] mb-6">وصال</div>
        <h1 class="text-2xl font-bold text-[#006e2f] mb-4">تحقق من بريدك الإلكتروني</h1>
        <p class="text-gray-600 mb-6">
            بعتنالك إيميل فيه رابط تأكيد الحساب. افتح الإيميل واضغط على الرابط.
        </p>
        <a href="/Account/Login" class="bg-[#22c55e] text-white px-6 py-3 rounded-lg hover:bg-[#006e2f] transition-colors">
            الرجوع لتسجيل الدخول
        </a>
    </div>
