@{
    ViewBag.Title = "تحقق من بريدك";
    Layout = null;
}
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>وصال - تحقق من بريدك</title>
    <link rel="stylesheet" href="~/css/wessal.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <style>
        .check-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--w-surface);
            padding: var(--w-space-md);
        }

        .check-card {
            background: var(--w-surface-container-lowest);
            border-radius: var(--w-radius-lg);
            box-shadow: var(--w-shadow-md);
            padding: var(--w-space-2xl);
            max-width: 480px;
            width: 100%;
            text-align: center;
        }

        .check-icon-wrap {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(99, 102, 241, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto var(--w-space-xl);
        }

            .check-icon-wrap .material-symbols-outlined {
                font-size: 40px;
                color: var(--w-primary);
                font-variation-settings: 'FILL' 1;
            }

        .check-brand {
            font-size: 28px;
            font-weight: 700;
            color: var(--w-primary);
            text-decoration: none;
            display: inline-block;
            margin-bottom: var(--w-space-xl);
        }

        .check-title {
            font-size: 24px;
            font-weight: 600;
            color: var(--w-on-surface);
            margin-bottom: var(--w-space-md);
        }

        .check-subtitle {
            font-size: 15px;
            color: var(--w-on-surface-variant);
            line-height: 1.7;
            margin-bottom: var(--w-space-xl);
        }

        .check-hint {
            font-size: 13px;
            color: var(--w-on-surface-variant);
            margin-top: var(--w-space-lg);
        }

            .check-hint a {
                color: var(--w-primary);
                font-weight: 600;
                text-decoration: none;
            }

                .check-hint a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>
    <div class="check-page">
        <div class="check-card w-animate-fadeInUp">

            <a asp-controller="Home" asp-action="Index" class="check-brand">
                <img src="~/images/MainLogo.png" alt="وصال" style="height: 38px; width: auto; object-fit: contain;" />
            </a>

            <div class="check-icon-wrap">
                <span class="material-symbols-outlined">mark_email_unread</span>
            </div>

            <h1 class="check-title">تحقق من بريدك الإلكتروني</h1>
            <p class="check-subtitle">
                بعتنالك إيميل فيه رابط تأكيد الحساب.<br />
                افتح الإيميل واضغط على الرابط عشان تكمل التسجيل.
            </p>

            <a asp-action="Login" asp-controller="Account" class="w-btn w-btn-primary w-btn-lg w-btn-full">
                <span class="material-symbols-outlined" style="font-size:18px;">login</span>
                الرجوع لتسجيل الدخول
            </a>

            <p class="check-hint">
                ملقتش الإيميل؟ تحقق من مجلد الـ Spam أو
                <a asp-action="Register" asp-controller="Account">سجّل من جديد</a>
            </p>

        </div>
    </div>
</body>
</html>