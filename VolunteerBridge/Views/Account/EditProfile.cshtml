@model VolunteerBridge.Models.User
@{
    ViewData["Title"] = "تعديل الملف الشخصي";
}

<div class="w-container w-py-xl w-animate-fadeIn" style="max-width: 640px;">

    @* ── Header ── *@
    <div class="d-flex align-items-center justify-content-between w-mb-xl">
        <div>
            <h1 class="w-h3 fw-bold mb-1">تعديل الملف الشخصي</h1>
            <p class="w-body-sm w-text-muted mb-0">عدّل بياناتك الشخصية واحفظ التغييرات.</p>
        </div>
        <a asp-action="Profile" asp-controller="Account" class="w-btn w-btn-ghost w-btn-sm">
            <span class="material-symbols-outlined">arrow_forward</span>
            العودة للملف
        </a>
    </div>

    @* ── Form Card ── *@
    <div class="w-card" style="border-top: 4px solid var(--w-primary);">
        <form asp-action="EditProfile" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />

            @* ── Validation Summary ── *@
            <div asp-validation-summary="ModelOnly" class="w-alert w-alert-error w-mb-lg"></div>

            @* ── Full Name ── *@
            <div class="w-input-group">
                <label asp-for="FullName" class="w-label w-mb-sm d-block">الاسم الكامل</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute" 
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">person</span>
                    <input asp-for="FullName" class="w-input" style="padding-right: 44px;" placeholder="أدخل اسمك الكامل" />
                </div>
                <span asp-validation-for="FullName" class="w-caption" style="color: var(--w-error); margin-top: 4px; display: block;"></span>
            </div>

            @* ── Email ── *@
            <div class="w-input-group">
                <label asp-for="Email" class="w-label w-mb-sm d-block">البريد الإلكتروني</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute" 
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">mail</span>
                    <input asp-for="Email" type="email" class="w-input" style="padding-right: 44px;" placeholder="example@domain.com" />
                </div>
                <span asp-validation-for="Email" class="w-caption" style="color: var(--w-error); margin-top: 4px; display: block;"></span>
            </div>

            @* ── City ── *@
            <div class="w-input-group">
                <label asp-for="City" class="w-label w-mb-sm d-block">
                    المدينة <span class="w-text-muted fw-normal">(اختياري)</span>
                </label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute" 
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">location_city</span>
                    <input asp-for="City" class="w-input" style="padding-right: 44px;" placeholder="مدينتك" />
                </div>
            </div>

            @* ── Phone ── *@
            <div class="w-input-group">
                <label asp-for="PhoneNumber" class="w-label w-mb-sm d-block">
                    رقم الهاتف <span class="w-text-muted fw-normal">(اختياري)</span>
                </label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute" 
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">phone</span>
                    <input asp-for="PhoneNumber" class="w-input" style="padding-right: 44px;" placeholder="05xxxxxxxx" />
                </div>
            </div>

            @* ── Divider ── *@
            <hr class="w-divider" />

            @* ── Buttons ── *@
            <div class="d-flex gap-3 flex-column flex-sm-row">
                <button type="submit" class="w-btn w-btn-primary flex-grow-1">
                    <span class="material-symbols-outlined">save</span>
                    حفظ التغييرات
                </button>
                <a asp-action="Profile" asp-controller="Account" class="w-btn w-btn-ghost flex-grow-1">
                    <span class="material-symbols-outlined">close</span>
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
