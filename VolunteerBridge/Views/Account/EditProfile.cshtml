@model VolunteerBridge.Models.User
@{
    ViewData["Title"] = "تعديل الملف الشخصي";
}

<div class="w-container w-py-xl w-animate-fadeIn" style="max-width: 640px;">

    @* ── Header ── *@
    <div class="d-flex align-items-center justify-content-between w-mb-xl">
        <div>
            <h1 class="w-h3 fw-bold mb-1">تعديل الملف الشخصي</h1>
            <p class="w-body-sm w-text-muted mb-0">عدّل بياناتك الشخصية واحفظ التغييرات.</p>
        </div>
        <a asp-action="Profile" asp-controller="Account" class="w-btn w-btn-ghost w-btn-sm">
            <span class="material-symbols-outlined">arrow_forward</span>
            العودة للملف
        </a>
    </div>

    @* ── Form Card ── *@
    <div class="w-card" style="border-top: 4px solid var(--w-primary);">
        <form asp-action="EditProfile" asp-controller="Account" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />

            @* ── Validation Summary ── *@
            <div asp-validation-summary="ModelOnly" class="w-alert w-alert-error w-mb-lg"></div>

            @* ── Profile Picture Upload ── *@
            <div class="d-flex flex-column align-items-center w-mb-xl">
                <div class="position-relative mb-3">
                    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <img id="profilePreview" src="@Model.ProfilePictureUrl" alt="صورة الملف الشخصي" class="w-avatar w-avatar-xl shadow" style="width: 120px; height: 120px; object-fit: cover; border: 4px solid white;" />
                    }
                    else
                    {
                        <div id="profilePreview" class="w-avatar w-avatar-xl shadow d-flex align-items-center justify-content-center" style="width: 120px; height: 120px; background: var(--w-primary); color: white; font-size: 2.5rem; border: 4px solid white;">
                            @(string.IsNullOrEmpty(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper())
                        </div>
                    }
                    
                    <label for="profilePicture" class="position-absolute bottom-0 end-0 bg-white rounded-circle shadow p-2" style="cursor: pointer; transform: translate(25%, 25%);">
                        <span class="material-symbols-outlined w-text-primary fs-5 d-block">photo_camera</span>
                    </label>
                    <input type="file" id="profilePicture" name="profilePicture" class="d-none" accept=".jpg,.jpeg,.png,.webp,.gif" onchange="previewImage(this)" />
                </div>
                <span class="w-body-sm w-text-muted">اضغط على أيقونة الكاميرا لتغيير الصورة</span>
            </div>

            @* ── Full Name ── *@
            <div class="w-input-group">
                <label asp-for="FullName" class="w-label w-mb-sm d-block">الاسم الكامل</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute"
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">person</span>
                    <input asp-for="FullName" class="w-input" style="padding-right: 44px;" placeholder="أدخل اسمك الكامل" />
                </div>
                <span asp-validation-for="FullName" class="w-caption" style="color: var(--w-error); margin-top: 4px; display: block;"></span>
            </div>

            @* ── Email ── *@
            <div class="w-input-group">
                <label asp-for="Email" class="w-label w-mb-sm d-block">البريد الإلكتروني</label>

                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute"
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">
                        mail
                    </span>

                    <input asp-for="Email"
                           type="email"
                           class="w-input"
                           readonly
                           style="padding-right: 44px; background-color: #f5f5f5; cursor: not-allowed;"
                           placeholder="example@domain.com" />
                </div>

                <span asp-validation-for="Email"
                      class="w-caption"
                      style="color: var(--w-error); margin-top: 4px; display: block;">
                </span>
            </div>

            @* ── City ── *@
            <div class="w-input-group">
                <label asp-for="City" class="w-label w-mb-sm d-block">
                    المدينة <span class="w-text-muted fw-normal">(اختياري)</span>
                </label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute"
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">location_city</span>
                    <input asp-for="City" class="w-input" style="padding-right: 44px;" placeholder="مدينتك" />
                </div>
            </div>

            @* ── Phone ── *@
            <div class="w-input-group">
                <label asp-for="PhoneNumber" class="w-label w-mb-sm d-block">
                    رقم الهاتف <span class="w-text-muted fw-normal">(اختياري)</span>
                </label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute"
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">phone</span>
                    <input asp-for="PhoneNumber" class="w-input" style="padding-right: 44px;" placeholder="05xxxxxxxx" />
                </div>
            </div>

            @* ── Bio ── *@
            <div class="w-input-group">
                <label asp-for="Bio" class="w-label w-mb-sm d-block">
                    نبذة عنك <span class="w-text-muted fw-normal">(اختياري)</span>
                </label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute"
                          style="top: 14px; right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">person_pin</span>
                    <textarea asp-for="Bio" class="w-input" rows="3"
                              style="padding-right: 44px; resize: vertical;"
                              placeholder="لم تُضف نبذة بعد، اكتب شيئاً عن نفسك..."></textarea>
                </div>
            </div>

            @* ── Skills ── *@
            <div class="w-input-group">
                <label asp-for="Skills" class="w-label w-mb-sm d-block">
                    المهارات <span class="w-text-muted fw-normal">(اختياري)</span>
                </label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute"
                          style="top: 50%; transform: translateY(-50%); right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">psychology</span>
                    <input asp-for="Skills" class="w-input" style="padding-right: 44px;"
                           placeholder="لم تُضف مهارات بعد — مثال: تصوير، تدريس، إسعاف أولي" />
                </div>
                <p class="w-caption w-text-muted mt-1 mb-0">افصل بين المهارات بفاصلة</p>
            </div>

            @* ── Experience ── *@
            <div class="w-input-group">
                <label asp-for="Experience" class="w-label w-mb-sm d-block">
                    الخبرات <span class="w-text-muted fw-normal">(اختياري)</span>
                </label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute"
                          style="top: 14px; right: 14px; color: var(--w-outline); font-size: 20px; pointer-events: none;">workspace_premium</span>
                    <textarea asp-for="Experience" class="w-input" rows="3"
                              style="padding-right: 44px; resize: vertical;"
                              placeholder="لم تُضف خبرات بعد، اذكر خبراتك السابقة..."></textarea>
                </div>
            </div>

            @* ── Divider ── *@
            <hr class="w-divider" />

            @* ── Buttons ── *@
            <div class="d-flex gap-3 flex-column flex-sm-row">
                <button type="submit" class="w-btn w-btn-primary flex-grow-1">
                    <span class="material-symbols-outlined">save</span>
                    حفظ التغييرات
                </button>
                <a asp-action="Profile" asp-controller="Account" class="w-btn w-btn-ghost flex-grow-1">
                    <span class="material-symbols-outlined">close</span>
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var preview = document.getElementById('profilePreview');
                    if (preview.tagName === 'IMG') {
                        preview.src = e.target.result;
                    } else {
                        // Create img element to replace div
                        var img = document.createElement('img');
                        img.id = 'profilePreview';
                        img.src = e.target.result;
                        img.alt = 'صورة الملف الشخصي';
                        img.className = preview.className;
                        img.style.cssText = preview.style.cssText;
                        preview.parentNode.replaceChild(img, preview);
                    }
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}