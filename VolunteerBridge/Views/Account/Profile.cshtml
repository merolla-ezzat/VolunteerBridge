@model VolunteerBridge.Models.User
@{
    ViewBag.Title = "الملف الشخصي";
}

<!DOCTYPE html>
<html class="light" dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>وصال - الملف الشخصي</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: { arabic: ['Rubik', 'sans-serif'] },
                    colors: {
                        "surface-tint": "#006e2f",
                        "surface": "#f3fcef",
                        "surface-container-low": "#edf6ea",
                        "outline": "#6d7b6c",
                        "background": "#f3fcef",
                        "on-primary": "#ffffff",
                        "on-surface": "#161d16",
                        "surface-container-lowest": "#ffffff",
                        "on-secondary": "#ffffff",
                        "error": "#ba1a1a",
                        "on-background": "#161d16",
                        "primary-container": "#22c55e",
                        "outline-variant": "#bccbb9",
                        "secondary": "#0051d5",
                        "primary": "#006e2f",
                        "on-primary-container": "#004b1e",
                        "on-surface-variant": "#3d4a3d",
                        "surface-container": "#e8f0e4",
                        "error-container": "#ffdad6",
                        "surface-container-high": "#e2ebde",
                        "secondary-fixed": "#dbe1ff",
                        "surface-bright": "#f3fcef"
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"
                    },
                    spacing: {
                        "lg": "24px", "xs": "4px", "md": "16px", "sm": "8px",
                        "xxl": "48px", "xl": "32px"
                    },
                    fontSize: {
                        "h2": ["32px", { "lineHeight": "1.3", "fontWeight": "700" }],
                        "body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "h3": ["24px", { "lineHeight": "1.4", "fontWeight": "600" }],
                        "label-bold": ["14px", { "lineHeight": "1.2", "fontWeight": "600" }],
                        "caption": ["12px", { "lineHeight": "1.2", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Rubik', sans-serif;
        }
    </style>
</head>
<body class="bg-background text-on-background min-h-screen p-md lg:p-xl font-arabic">

    <div class="max-w-[800px] mx-auto space-y-lg">

        <!-- Header -->
        <div class="flex items-center justify-between">
            <a href="/" class="text-h2 font-black text-primary">وصال</a>
            <a asp-action="Logout" asp-controller="Account"
               class="flex items-center gap-sm text-label-bold text-on-surface-variant hover:text-error transition-colors">
                <span class="material-symbols-outlined text-[20px]">logout</span>
                تسجيل الخروج
            </a>
        </div>

        <!-- Profile Card -->
        <div class="bg-surface-container-lowest rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] overflow-hidden">

            <!-- Cover -->
            <div class="h-32 bg-gradient-to-l from-primary to-primary-container relative">
                <div class="absolute -bottom-10 right-xl">
                    <div class="w-20 h-20 rounded-full bg-surface-container-lowest border-4 border-surface-container-lowest flex items-center justify-center shadow-md">
                        <span class="material-symbols-outlined text-[40px] text-primary" style="font-variation-settings: 'FILL' 1;">account_circle</span>
                    </div>
                </div>
            </div>

            <!-- Info -->
            <div class="pt-14 px-xl pb-xl">
                <div class="flex items-start justify-between flex-wrap gap-md">
                    <div>
                        <h2 class="text-h3 font-semibold text-on-surface">@Model.FullName</h2>
                        <p class="text-body-sm text-on-surface-variant mt-xs">@Model.Email</p>
                    </div>
                    <a asp-action="EditProfile" asp-controller="Account"
                       class="flex items-center gap-sm bg-surface-container px-md py-sm rounded-lg text-label-bold text-primary hover:bg-surface-container-high transition-colors">
                        <span class="material-symbols-outlined text-[18px]">edit</span>
                        تعديل الملف
                    </a>
                </div>

                <!-- Divider -->
                <div class="border-t border-outline-variant my-lg"></div>

                <!-- Details Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-md">

                    <!-- City -->
                    <div class="flex items-center gap-md bg-surface-container p-md rounded-lg">
                        <div class="w-10 h-10 rounded-full bg-surface-container-low flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">location_city</span>
                        </div>
                        <div>
                            <p class="text-caption text-on-surface-variant">المدينة</p>
                            <p class="text-body-md text-on-surface font-medium">
                                @(string.IsNullOrEmpty(Model.City) ? "غير محدد" : Model.City)
                            </p>
                        </div>
                    </div>

                    <!-- Phone -->
                    <div class="flex items-center gap-md bg-surface-container p-md rounded-lg">
                        <div class="w-10 h-10 rounded-full bg-surface-container-low flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">phone</span>
                        </div>
                        <div>
                            <p class="text-caption text-on-surface-variant">رقم الهاتف</p>
                            <p class="text-body-md text-on-surface font-medium">
                                @(string.IsNullOrEmpty(Model.PhoneNumber) ? "غير محدد" : Model.PhoneNumber)
                            </p>
                        </div>
                    </div>

                    <!-- Points -->
                    <div class="flex items-center gap-md bg-surface-container p-md rounded-lg">
                        <div class="w-10 h-10 rounded-full bg-surface-container-low flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">stars</span>
                        </div>
                        <div>
                            <p class="text-caption text-on-surface-variant">النقاط</p>
                            <p class="text-body-md text-on-surface font-medium">
                                @(Model.TotalPoints != 0 ? Model.TotalPoints.ToString() : "0") نقطة
                            </p>
                        </div>
                    </div>

                    <!-- Rating -->
                    <div class="flex items-center gap-md bg-surface-container p-md rounded-lg">
                        <div class="w-10 h-10 rounded-full bg-surface-container-low flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-[20px]" 
                                  style="font-variation-settings: 'FILL' 1;">grade</span>
                        </div>
                        <div>
                            <p class="text-caption text-on-surface-variant">التقييم</p>
                            <p class="text-body-md text-on-surface font-medium">
                                @* Modified by Yousef: keep the profile values simple and add a shortcut to the points history page. *@
                                @if (Model.AverageRating > 0)
                                {
                                    @Model.AverageRating.ToString("0.0") <span>من 5</span>
                                }
                                else
                                {
                                    <span>لا يوجد تقييم بعد</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="flex items-center gap-md bg-surface-container p-md rounded-lg">
                        <div class="w-10 h-10 rounded-full bg-surface-container-low flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-[20px]"
                                  style="font-variation-settings: 'FILL' 1;">military_tech</span>
                        </div>
                        <div>
                            <p class="text-caption text-on-surface-variant">المستوى</p>
                            <p class="text-body-md text-on-surface font-medium">
                                @switch (Model.Level)
                                {
                                    case UserLevel.Newcomer:
                                        <span>مبتدئ الخير</span>
                                        break;
                                    case UserLevel.Helper:
                                        <span>صانع الفرق</span>
                                        break;
                                    case UserLevel.Trusted:
                                        <span>موثوق العطاء</span>
                                        break;
                                    case UserLevel.Champion:
                                        <span>بطل المجتمع</span>
                                        break;
                                }
                            </p>
                        </div>
                    </div>

                    <div class="mt-lg flex flex-col sm:flex-row gap-md">
                        <a asp-controller="Points" asp-action="History"
                           class="flex-1 bg-surface-container px-md py-sm rounded-lg text-label-bold text-primary hover:bg-surface-container-high transition-colors text-center">
                            سجل النقاط
                        </a>
                        <a asp-controller="ServiceRequests" asp-action="MyRequests"
                           class="flex-1 bg-surface-container px-md py-sm rounded-lg text-label-bold text-primary hover:bg-surface-container-high transition-colors text-center">
                            طلباتي
                        </a>
                    </div>

                </div>
            </div>
        </div>

    </div>

</body>
</html>
