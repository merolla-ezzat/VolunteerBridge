@model VolunteerBridge.Models.User
@{
    ViewBag.Title = "الملف الشخصي";
}

<div class="w-container pt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Profile Hero Section -->
            <div class="w-glass-premium p-0 overflow-hidden mb-4 w-animate-fadeInUp">
                <div class="p-5 text-center position-relative" style="height: 180px; background: radial-gradient(circle at 20% 30%, rgba(99, 102, 241, 0.4), transparent 50%), radial-gradient(circle at 80% 70%, rgba(168, 85, 247, 0.3), transparent 50%), var(--w-primary); background-blend-mode: overlay;">
                    <div class="position-absolute start-50 translate-middle-x" style="bottom: -55px;">
                        <div class="bg-white p-1 rounded-circle shadow-lg" style="background: rgba(255, 255, 255, 0.2) !important; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3);">
                            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                            {
                                <img src="@Model.ProfilePictureUrl" alt="@Model.FullName" class="rounded-circle" style="width: 110px; height: 110px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="w-bg-surface-container rounded-circle d-flex align-items-center justify-content-center overflow-hidden" style="width: 110px; height: 110px; background: var(--w-surface-container-highest);">
                                    <span class="material-symbols-outlined w-text-primary" style="font-size: 80px; font-variation-settings: 'FILL' 1;">account_circle</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="pt-5 pb-5 text-center mt-4">
                    <h1 class="w-h2 mb-1 w-aurora-text">@Model.FullName</h1>
                    <p class="w-text-muted mb-4">@Model.Email</p>
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <button type="button" onclick="window.WessalChat && window.WessalChat.toggle()" class="w-btn w-btn-primary w-btn-sm px-4">
                            <span class="material-symbols-outlined w-icon-xs">chat</span>
                            الرسائل
                        </button>
                        <a asp-action="EditProfile" asp-controller="Account" class="w-btn w-btn-primary w-btn-sm px-4">
                            <span class="material-symbols-outlined w-icon-xs">edit</span>
                            تعديل الملف
                        </a>
                        <a asp-action="Logout" asp-controller="Account" class="w-btn w-btn-outline-danger w-btn-sm px-4">
                            <span class="material-symbols-outlined w-icon-xs">logout</span>
                            خروج
                        </a>
                    </div>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="row g-4 mb-4 w-animate-fadeInUp w-delay-100">
                <!-- Points Card -->
                <div class="col-md-4">
                    <div class="w-glass-premium text-center h-100 p-4">
                        <div class="w-icon-container w-mx-auto w-mb-md" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary); box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);">
                            <span class="material-symbols-outlined w-icon-lg" style="font-variation-settings: 'FILL' 1;">stars</span>
                        </div>
                        <h3 class="w-caption w-text-muted mb-1">إجمالي النقاط</h3>
                        <p class="w-h2 mb-0 w-aurora-text">@(Model.TotalPoints != 0 ? Model.TotalPoints.ToString("N0") : "0")</p>
                        <p class="w-caption w-text-primary mt-1 fw-bold">نقطة تطوعية</p>
                    </div>
                </div>

                <!-- Rating Card -->
                <div class="col-md-4">
                    <div class="w-glass-premium text-center h-100 p-4">
                        <div class="w-icon-container w-mx-auto w-mb-md" style="background: rgba(168, 85, 247, 0.1); color: var(--w-secondary); box-shadow: 0 0 20px rgba(168, 85, 247, 0.2);">
                            <span class="material-symbols-outlined w-icon-lg" style="font-variation-settings: 'FILL' 1;">grade</span>
                        </div>
                        <h3 class="w-caption w-text-muted mb-1">تقييم المتطوع</h3>
                        @if (Model.AverageRating > 0)
                        {
                            <p class="w-h2 mb-0 w-aurora-text" style="--aurora-1: var(--w-secondary); --aurora-2: #ec4899;">@Model.AverageRating.ToString("0.0") <span class="w-body-sm w-text-faint">/ 5</span></p>
                            <div class="d-flex justify-content-center mt-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="material-symbols-outlined" style="font-size: 16px; color: @(i <= Math.Round(Model.AverageRating) ? "#fbbf24" : "rgba(0,0,0,0.1)"); font-variation-settings: 'FILL' 1;">star</span>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="w-body-md mb-0 py-2">لا يوجد تقييم بعد</p>
                        }
                    </div>
                </div>

                <!-- Level Card -->
                <div class="col-md-4">
                    <div class="w-glass-premium text-center h-100 p-4">
                        <div class="w-icon-container w-mx-auto w-mb-md" style="background: rgba(16, 185, 129, 0.1); color: #10b981; box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);">
                            <span class="material-symbols-outlined w-icon-lg" style="font-variation-settings: 'FILL' 1;">military_tech</span>
                        </div>
                        <h3 class="w-caption w-text-muted mb-1">المستوى الحالي</h3>
                        <div class="mt-2">
                            @switch (Model.Level)
                            {
                                case UserLevel.Newcomer:
                                    <span class="w-chip badge-newcomer px-3">مبتدئ الخير</span>
                                    break;
                                case UserLevel.Helper:
                                    <span class="w-chip badge-helper px-3">صانع الفرق</span>
                                    break;
                                case UserLevel.Trusted:
                                    <span class="w-chip badge-trusted px-3">موثوق العطاء</span>
                                    break;
                                case UserLevel.Champion:
                                    <span class="w-chip badge-champion px-3">بطل المجتمع</span>
                                    break;
                            }
                        </div>
                        <p class="w-caption w-text-muted mt-2">استمر في العطاء لترقية مستواك</p>
                    </div>
                </div>
            </div>

            <!-- Details and Activity -->
            <div class="row g-4 w-animate-fadeInUp w-delay-200">
                <div class="col-md-6">
                    <div class="w-glass-premium h-100 p-4">
                        <h3 class="w-h5 mb-4 fw-bold">المعلومات الشخصية</h3>

                        <div class="d-flex align-items-center mb-4">
                            <div class="w-icon-container w-icon-container-sm me-3" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary);">
                                <span class="material-symbols-outlined w-icon-md">location_on</span>
                            </div>
                            <div>
                                <p class="w-caption w-text-muted mb-0">المدينة</p>
                                <p class="w-body-md font-weight-bold mb-0">@(string.IsNullOrEmpty(Model.City) ? "غير محدد" : Model.City)</p>
                            </div>
                        </div>

                        <div class="d-flex align-items-center mb-0">
                            <div class="w-icon-container w-icon-container-sm me-3" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary);">
                                <span class="material-symbols-outlined w-icon-md">phone</span>
                            </div>
                            <div>
                                <p class="w-caption w-text-muted mb-0">رقم الهاتف</p>
                                <p class="w-body-md font-weight-bold mb-0">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "غير محدد" : Model.PhoneNumber)</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="w-glass-premium h-100 p-4">
                        <h3 class="w-h5 mb-4 fw-bold">إجراءات سريعة</h3>
                        <div class="d-grid gap-3">
                            <a asp-controller="Points" asp-action="History" class="w-btn w-btn-outline w-btn-full justify-content-between p-3 border-0" style="background: rgba(99, 102, 241, 0.05);">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="w-icon-container w-icon-container-sm" style="background: white; color: var(--w-primary);">
                                        <span class="material-symbols-outlined">history</span>
                                    </div>
                                    <span class="fw-bold">سجل النقاط والمساهمات</span>
                                </div>
                                <span class="material-symbols-outlined">chevron_left</span>
                            </a>
                            <a asp-controller="ServiceRequests" asp-action="MyRequests" class="w-btn w-btn-outline w-btn-full justify-content-between p-3 border-0" style="background: rgba(99, 102, 241, 0.05);">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="w-icon-container w-icon-container-sm" style="background: white; color: var(--w-primary);">
                                        <span class="material-symbols-outlined">assignment</span>
                                    </div>
                                    <span class="fw-bold">طلباتي (المقدمة والمستلمة)</span>
                                </div>
                                <span class="material-symbols-outlined">chevron_left</span>
                            </a>
                            <a asp-controller="Acceptances" asp-action="MyTasks" class="w-btn w-btn-outline w-btn-full justify-content-between p-3 border-0" style="background: rgba(99, 102, 241, 0.05);">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="w-icon-container w-icon-container-sm" style="background: white; color: var(--w-primary);">
                                        <span class="material-symbols-outlined">task</span>
                                    </div>
                                    <span class="fw-bold">مهامي</span>
                                </div>
                                <span class="material-symbols-outlined">chevron_left</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bio, Skills, Experience -->
            <div class="row g-4 mt-0 w-animate-fadeInUp w-delay-300">

                <!-- Bio -->
                <div class="col-12">
                    <div class="w-glass-premium p-4 position-relative overflow-hidden">
                        <!-- decorative background icon -->
                        <span class="material-symbols-outlined position-absolute" style="font-size: 150px; color: rgba(99, 102, 241, 0.03); left: -20px; top: -20px; z-index: 0; font-variation-settings: 'FILL' 1; transform: rotate(-15deg);">format_quote</span>
                        
                        <div class="position-relative" style="z-index: 1;">
                            <h3 class="w-h5 mb-3 fw-bold d-flex align-items-center gap-2">
                                <div class="w-icon-container w-icon-container-sm" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary);">
                                    <span class="material-symbols-outlined" style="font-size: 20px; font-variation-settings:'FILL' 1;">person_pin</span>
                                </div>
                                نبذة شخصية
                            </h3>
                            @if (!string.IsNullOrEmpty(Model.Bio))
                            {
                                <div class="p-3 rounded-3" style="background: rgba(255, 255, 255, 0.4); border: 1px solid rgba(255, 255, 255, 0.5);">
                                    <p class="w-body-md w-text-muted mb-0" style="line-height:1.8;">@Model.Bio</p>
                                </div>
                            }
                            else
                            {
                                <div class="p-4 rounded-3 text-center" style="background: rgba(255, 255, 255, 0.3); border: 1px dashed rgba(99, 102, 241, 0.3);">
                                    <span class="material-symbols-outlined w-mb-sm" style="font-size:32px; color: var(--w-outline);">edit_note</span>
                                    <p class="w-body-md mb-3" style="color: var(--w-text-secondary);">أخبرنا المزيد عن نفسك، اهتماماتك وشغفك بالتطوع.</p>
                                    <a asp-action="EditProfile" asp-controller="Account" class="w-btn w-btn-outline w-btn-sm rounded-pill px-4" style="border-color: rgba(99, 102, 241, 0.2); color: var(--w-primary);">
                                        <span class="material-symbols-outlined w-icon-xs">add</span> أضف نبذة شخصية
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Skills -->
                <div class="col-md-6">
                    <div class="w-glass-premium p-4 h-100 position-relative overflow-hidden">
                        <div class="position-relative" style="z-index: 1;">
                            <h3 class="w-h5 mb-4 fw-bold d-flex align-items-center gap-2">
                                <div class="w-icon-container w-icon-container-sm" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary);">
                                    <span class="material-symbols-outlined" style="font-size: 20px; font-variation-settings:'FILL' 1;">psychology</span>
                                </div>
                                المهارات
                            </h3>
                            @if (!string.IsNullOrEmpty(Model.Skills))
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var skill in Model.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <div class="d-flex align-items-center gap-1 rounded-pill" style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1)); border: 1px solid rgba(99, 102, 241, 0.2); padding: 6px 16px;">
                                            <span class="material-symbols-outlined" style="font-size: 14px; color: var(--w-primary);">verified</span>
                                            <span class="w-body-sm fw-bold" style="color: var(--w-primary);">@skill.Trim()</span>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="p-4 rounded-3 text-center h-100 d-flex flex-column justify-content-center" style="background: rgba(255, 255, 255, 0.3); border: 1px dashed rgba(99, 102, 241, 0.3);">
                                    <span class="material-symbols-outlined w-mb-sm" style="font-size:32px; color: var(--w-outline);">model_training</span>
                                    <p class="w-body-md mb-3" style="color: var(--w-text-secondary);">ما هي المهارات التي تتقنها ويمكنك المساعدة بها؟</p>
                                    <div class="mt-auto">
                                        <a asp-action="EditProfile" asp-controller="Account" class="w-btn w-btn-outline w-btn-sm rounded-pill px-4" style="border-color: rgba(99, 102, 241, 0.2); color: var(--w-primary);">
                                            <span class="material-symbols-outlined w-icon-xs">add</span> أضف مهاراتك
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Experience -->
                <div class="col-md-6">
                    <div class="w-glass-premium p-4 h-100 position-relative overflow-hidden">
                        <div class="position-relative" style="z-index: 1;">
                            <h3 class="w-h5 mb-4 fw-bold d-flex align-items-center gap-2">
                                <div class="w-icon-container w-icon-container-sm" style="background: rgba(168, 85, 247, 0.1); color: var(--w-secondary);">
                                    <span class="material-symbols-outlined" style="font-size: 20px; font-variation-settings:'FILL' 1;">workspace_premium</span>
                                </div>
                                الخبرات
                            </h3>
                            @if (!string.IsNullOrEmpty(Model.Experience))
                            {
                                <div class="p-3 rounded-3" style="background: rgba(255, 255, 255, 0.4); border: 1px solid rgba(255, 255, 255, 0.5);">
                                    <div class="d-flex gap-3">
                                        <div class="mt-1">
                                            <span class="material-symbols-outlined" style="color: var(--w-secondary); font-variation-settings: 'FILL' 1;">arrow_drop_down_circle</span>
                                        </div>
                                        <p class="w-body-md w-text-muted mb-0" style="line-height:1.8;">@Model.Experience</p>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="p-4 rounded-3 text-center h-100 d-flex flex-column justify-content-center" style="background: rgba(255, 255, 255, 0.3); border: 1px dashed rgba(168, 85, 247, 0.3);">
                                    <span class="material-symbols-outlined w-mb-sm" style="font-size:32px; color: var(--w-outline);">work_history</span>
                                    <p class="w-body-md mb-3" style="color: var(--w-text-secondary);">شاركنا خبراتك السابقة والأعمال التطوعية التي شاركت بها.</p>
                                    <div class="mt-auto">
                                        <a asp-action="EditProfile" asp-controller="Account" class="w-btn w-btn-outline w-btn-sm rounded-pill px-4" style="border-color: rgba(168, 85, 247, 0.2); color: var(--w-secondary);">
                                            <span class="material-symbols-outlined w-icon-xs">add</span> أضف خبراتك
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>