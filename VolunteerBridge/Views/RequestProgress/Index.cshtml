@model VolunteerBridge.ViewModels.RequestProgressViewModel
@using VolunteerBridge.ViewModels

@{
    ViewData["Title"] = "تتبع الطلب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* ─── Link to custom CSS (add once at top of view) ─────────────── *@
<link rel="stylesheet" href="~/css/progress-tracker.css" />

<div class="w-container w-py-xl w-animate-fadeIn" dir="rtl">

    @* --- Background Glows --- *@
    <div class="position-fixed top-0 start-50 translate-middle-x w-100 h-100 overflow-hidden" style="z-index: -1; pointer-events: none;">
        <div class="position-absolute tracker-ambient-glow tracker-ambient-glow-1" style="width: 500px; height: 500px; background: radial-gradient(circle, rgba(16, 185, 129, 0.06) 0%, transparent 70%); top: -100px; right: -150px; filter: blur(80px);"></div>
        <div class="position-absolute tracker-ambient-glow tracker-ambient-glow-2" style="width: 400px; height: 400px; background: radial-gradient(circle, rgba(99, 102, 241, 0.06) 0%, transparent 70%); bottom: -50px; left: -100px; filter: blur(60px);"></div>
    </div>

    @* ── Title ── *@
    <div class="d-flex justify-content-between align-items-center w-mb-xl">
        <div>
            <h2 class="w-h2 mb-1 w-aurora-text">تتبع الطلب</h2>
            <p class="w-body-md w-text-muted mb-0">@Model.Request.Title</p>
        </div>
        <div class="tracker-floating-badge w-chip w-chip-primary w-glass-premium shadow-sm">
            <span class="w-body-sm fw-bold">@Model.ProgressPercent%</span>
        </div>
    </div>

    @* ── Current Stage Alert ─────────────────────────────────────── *@
    @{
        var alertClass = "w-chip-secondary";
        var alertIcon = "info";
        if (Model.ProgressPercent == 100) {
            alertClass = "w-chip-success";
            alertIcon = "check_circle";
        }
    }
    <div class="w-glass-premium p-4 mb-5 d-flex align-items-center gap-3 tracker-info-card" style="border-radius: var(--w-radius-xl); background: rgba(var(--w-primary-rgb), 0.02); border: 1px solid rgba(255,255,255,0.05);">
        <div class="w-avatar w-avatar-md @alertClass" style="animation: w-tracker-pulse 3s infinite cubic-bezier(0.66, 0, 0, 1);">
            <span class="material-symbols-outlined fs-4">@alertIcon</span>
        </div>
        <div>
            <div class="w-body-md fw-bold">المرحلة الحالية: @Model.CurrentStageArabic</div>
            <small class="w-body-sm w-text-muted">@Model.CurrentStageLabel</small>
        </div>
    </div>

    @* ── Timeline (desktop: horizontal | mobile: vertical) ───────── *@
    <div class="tracker-timeline d-none d-md-flex w-mb-xl" id="timelineDesktop">
        @foreach (var stage in Model.Stages)
        {
            <div class="tracker-step @(stage.State == StageState.Completed ? "step-done" : stage.State == StageState.Current ? "step-active" : "step-pending")">
                <div class="step-icon">
                    <span class="material-symbols-outlined">@stage.Icon</span>
                </div>
                <div class="step-line"></div>
                <div class="step-label">
                    <div class="label-ar">@stage.LabelAr</div>
                    <div class="label-en">@stage.Label</div>
                </div>
            </div>
        }
    </div>

    @* ── Timeline vertical (mobile) ─────────────────────────────── *@
    <div class="tracker-timeline-vertical d-md-none w-mb-xl">
        @foreach (var stage in Model.Stages)
        {
            <div class="v-step @(stage.State == StageState.Completed ? "step-done" : stage.State == StageState.Current ? "step-active" : "step-pending")">
                <div class="v-icon-col">
                    <div class="v-icon"><span class="material-symbols-outlined">@stage.Icon</span></div>
                    @if (stage.Number < 7)
                    {
                        <div class="v-line"></div>
                    }
                </div>
                <div class="v-label">
                    <span class="label-ar">@stage.LabelAr</span>
                    <span class="label-en">@stage.Label</span>
                </div>
            </div>
        }
    </div>

    @* ── Info Cards: Requester + Volunteer side by side ─────────── *@
    <div class="row g-4 w-mb-xl">

        @* Requester Card *@
        <div class="col-md-6">
            <div class="tracker-info-card w-glass-premium h-100 p-4" style="border-radius: var(--w-radius-xl);">
                <div class="d-flex align-items-center mb-4">
                    <span class="material-symbols-outlined w-text-primary me-2">person</span>
                    <h5 class="w-h6 mb-0 fw-bold">صاحب الطلب</h5>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="w-avatar w-avatar-lg" style="background: rgba(99, 102, 241, 0.1); color: var(--w-primary);">
                        <span class="w-h4 mb-0">@(Model.Request.Requester?.FullName.FirstOrDefault())</span>
                    </div>
                    <div>
                        <div class="w-body-md fw-bold">@Model.Request.Requester?.FullName</div>
                        <div class="w-body-sm w-text-muted">@Model.Request.Requester?.City</div>
                    </div>
                </div>
            </div>
        </div>

        @* Volunteer Card *@
        <div class="col-md-6">
            <div class="tracker-info-card w-glass-premium h-100 p-4" style="border-radius: var(--w-radius-xl);">
                <div class="d-flex align-items-center mb-4">
                    <span class="material-symbols-outlined w-text-secondary me-2">volunteer_activism</span>
                    <h5 class="w-h6 mb-0 fw-bold">المتطوع</h5>
                </div>
                @if (Model.ActiveAcceptance?.Volunteer != null)
                {
                    <div class="d-flex align-items-center gap-3">
                        <div class="w-avatar w-avatar-lg" style="background: rgba(16, 185, 129, 0.1); color: var(--w-secondary);">
                            <span class="w-h4 mb-0">@(Model.ActiveAcceptance.Volunteer.FullName.FirstOrDefault())</span>
                        </div>
                        <div>
                            <div class="w-body-md fw-bold">@Model.ActiveAcceptance.Volunteer.FullName</div>
                            <div class="w-rating-display w-body-sm w-text-muted">
                                <span class="material-symbols-outlined text-warning w-icon-xs" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span>@Model.ActiveAcceptance.Volunteer.AverageRating.ToString("0.0")</span>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center gap-3 opacity-50">
                        <div class="w-avatar w-avatar-lg" style="background: var(--w-surface-hover); color: var(--w-text-muted);">
                            <span class="material-symbols-outlined">hourglass_empty</span>
                        </div>
                        <div class="w-body-md w-text-muted">لم يتم قبول متطوع بعد</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Conditional Action Buttons ─────────────────────────────── *@
    <div class="d-flex gap-3 flex-wrap justify-content-end w-animate-fadeInUp" style="animation-delay: 0.1s;">
        <a asp-controller="ServiceRequests" asp-action="Details"
           asp-route-id="@Model.Request.RequestId"
           class="w-btn w-btn-outline w-glass-premium px-4">
            <span class="material-symbols-outlined fs-5">arrow_forward</span>
            <span>تفاصيل الطلب</span>
        </a>

        @if (Model.CanCancel)
        {
            <a asp-controller="ServiceRequests" asp-action="Cancel"
               asp-route-id="@Model.Request.RequestId"
               class="w-btn w-btn-outline-error px-4">
                <span class="material-symbols-outlined fs-5">cancel</span>
                <span>إلغاء الطلب</span>
            </a>
        }

        @if (Model.CanRate)
        {
            <a asp-controller="Rating" asp-action="Create"
               asp-route-acceptanceId="@Model.ActiveAcceptance!.AcceptanceId"
               class="w-btn w-btn-secondary px-4">
                <span class="material-symbols-outlined fs-5">star</span>
                <span>تقييم المتطوع</span>
            </a>
        }

        @if (Model.CanMarkComplete)
        {
            <a asp-controller="Volunteer" asp-action="MarkComplete"
               asp-route-id="@Model.ActiveAcceptance!.AcceptanceId"
               class="w-btn w-btn-success px-4">
                <span class="material-symbols-outlined fs-5">check_circle</span>
                <span>تأكيد الإتمام</span>
            </a>
        }
    </div>

</div>

@* ── Toast Notification (auto-refresh) ─────────────────────────── *@
<div class="toast-container position-fixed bottom-0 start-0 p-4" dir="rtl">
    <div id="refreshToast" class="toast w-glass-premium border-0" role="alert" style="border-radius: var(--w-radius-lg);">
        <div class="toast-header border-0 bg-transparent">
            <span class="material-symbols-outlined w-text-primary me-2" style="animation: w-spin-slow 4s linear infinite;">refresh</span>
            <strong class="me-auto w-body-md">تحديث</strong>
            <button type="button" class="w-btn w-btn-ghost w-btn-sm p-1" data-bs-dismiss="toast" aria-label="إغلاق">
                <span class="material-symbols-outlined" style="font-size: 20px;">close</span>
            </button>
        </div>
        <div class="toast-body w-text-muted">تم تحديث حالة الطلب</div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-refresh every 30 seconds
        const requestId = @Model.Request.RequestId;
        let lastStage = @Model.CurrentStage;

        async function checkProgress() {
          try {
            const res = await fetch(`/RequestProgress/ProgressData/${requestId}`);
            const data = await res.json();
            if (data.stage !== lastStage) {
              lastStage = data.stage;
              // Show toast then reload
              const toastEl = document.getElementById('refreshToast');
              const toast = new bootstrap.Toast(toastEl, { delay: 2000 });
              toast.show();
              setTimeout(() => location.reload(), 2200);
            }
          } catch(e) { /* silent fail */ }
        }

        setInterval(checkProgress, 30000);
    </script>
}
